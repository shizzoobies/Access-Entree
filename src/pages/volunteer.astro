---
import Layout from '../layouts/Layout.astro';

const positions = [
  {
    title: 'Volunteer Technical Artist (Unity)',
    type: 'Remote · Volunteer',
    desc: 'Help build the visual assets for our Unity-based game projects.',
  },
  {
    title: 'Volunteer Kickstarter Launch Campaign Manager',
    type: 'Remote · Volunteer · Marketing',
    desc: 'Lead the Kickstarter launch campaign for our disability-themed mobile game. Help us reach our funding goals and spread the word.',
  },
];
---

<Layout title="Volunteer" description="Volunteer with FDAAF — help empower the disability community by promoting accessibility and empathy through visual media.">

  <!-- HERO -->
  <section style="position:relative; height:420px; overflow:hidden; display:flex; align-items:center; justify-content:center;">
    <img src="/images/volunteer-hero.jpg" alt="Volunteers working together" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;" />
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%);"></div>
    <div style="position:relative; z-index:2; text-align:center; padding:0 2rem; max-width:800px;">
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3.4rem); color:#fff; font-weight:700; margin:0; text-shadow:0 2px 12px rgba(0,0,0,0.4);">Volunteer with FDAAF</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:1100px; margin:0 auto;" class="reveal">
      <div class="section-heading" style="text-align:center;">
        <span class="label">Join the Team</span>
        <h2>Volunteer with us</h2>
              </div>
      <div style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#333; line-height:1.8; margin-top:1.5rem; display:grid; grid-template-columns:1fr 1fr; gap:2rem;" class="volunteer-intro-grid">
        <div>
          <p style="margin-bottom:1rem;">Our purpose is to raise awareness and create inclusion for the disability community. We rely on our dedicated volunteers to make our projects a reality.</p>
          <p style="margin-bottom:1rem;">When you volunteer with us, you help empower the disability community by promoting accessibility and empathy.</p>
        </div>
        <div>
          <p style="margin-bottom:1rem;">Our entire team works remotely from all across the US, interacting online and working on your own schedules.</p>
          <p style="margin-bottom:1rem;">We are looking for independent, driven, and organized people who want to be a part of something different and create positive change through visual media.</p>
          <p>There are various positions being offered so, regardless of your talent you can be involved with creating a better future.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OPEN POSITIONS -->
  <section style="padding:3.5rem 2rem; background:#f7f7f7;">
    <div style="max-width:900px; margin:0 auto;">
      <div class="section-heading reveal">
        <span class="label">Now Hiring</span>
        <h2>Open Positions</h2>
              </div>
      <div style="display:flex; flex-direction:column; gap:1.5rem; margin-top:2.5rem;">
        {positions.map((pos, i) => (
          <div class="reveal" style={`transition-delay:${i*80}ms; background:#fff; border:1px solid #eee; padding:1.75rem; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:flex-start; gap:1.5rem;`}>
            <div style="flex:1; min-width:200px;">
              <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.95rem; text-transform:uppercase; letter-spacing:0.05em; color:#000; margin:0 0 0.4rem;">{pos.title}</h3>
              <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#35CCC0; margin:0 0 0.75rem;">{pos.type}</p>
              <p style="font-family:'Raleway',sans-serif; font-size:0.85rem; color:#555; line-height:1.6;">{pos.desc}</p>
            </div>
            <a href="/contact/" class="btn-teal" style="white-space:nowrap; align-self:flex-start;">More Details</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STUDENTS -->
  <section style="padding:3rem 2rem; background:#fff; text-align:center;">
    <div style="max-width:650px; margin:0 auto;" class="reveal">
      <div class="section-heading">
        <span class="label">Students & Veterans</span>
        <h2>Student Opportunities</h2>
              </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#333; line-height:1.8; margin-top:1.5rem;">
        Student volunteers can use positions as internship experience. We coordinate with partner schools to arrange credit where available. Students and military veterans are especially welcome!
      </p>
      <div style="margin-top:1.75rem;">
        <a href="/contact/" class="btn-teal">Contact Us to Learn More</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section style="padding:3rem 2rem; background:#f7f7f7; text-align:center;">
    <div style="max-width:500px; margin:0 auto;" class="reveal">
      <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:1rem; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.25rem;">Subscribe to our Newsletter</h3>
      <form style="display:flex; gap:0.5rem; flex-wrap:wrap;" action="#" method="post">
        <input type="email" name="email" placeholder="Your email address" required style="flex:1; min-width:220px;" />
        <button type="submit" class="btn-teal">Subscribe</button>
      </form>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 700px) {
    .volunteer-intro-grid { grid-template-columns: 1fr !important; }
  }
</style>
