---
import Layout from '../layouts/Layout.astro';

const tiers = [
  { amount: '$25', desc: 'Funds accessibility features in our games, making them playable for more users.' },
  { amount: '$50', desc: "Supports volunteer training to build empathy events like 'Wheelchaired for a Day.'" },
  { amount: '$100', desc: 'Contributes to game development, bringing stories of empowerment to thousands.' },
  { amount: '$250+', desc: 'Enables sponsorship of new projects, amplifying voices in the disability community.' },
];
---

<Layout title="Donate" description="Support FDAAF — empowering the disability community through media and innovation. Your donation makes a difference.">

  <!-- PAGE TITLE -->
  <section style="padding:3rem 1rem 2.5rem; text-align:center; background:#fff;">
    <div class="page-title-block">
            <h1>Donate to FDAAF</h1>
    </div>
  </section>

  <!-- MISSION -->
  <section style="padding:3.5rem 2rem; background:#fff; text-align:center;">
    <div style="max-width:800px; margin:0 auto;" class="reveal">
      <div class="section-heading">
        <span class="label">Make a Difference</span>
        <h2>Your Donation Makes a Difference!</h2>
              </div>
      <p style="font-family:'Raleway',sans-serif; font-size:1em; color:#333; line-height:1.8; margin-top:1.5rem;">
        Support FDAAF: Empowering the Disability Community Through Media and Innovation
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#555; line-height:1.8; margin-top:1rem;">
        At the Florida Disability Access and Awareness Foundation (FDAAF), we're on a mission to create a more inclusive world. We develop interactive media, including video games and empathy-building experiences, that give a voice to people with disabilities.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#555; line-height:1.8; margin-top:1rem;">
        Every donation is used to boost awareness and accessibility for the disability community through media and technology.
      </p>
    </div>
  </section>

  <!-- TIERS -->
  <section style="padding:3.5rem 2rem; background:#f7f7f7;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal">
        <span class="label">Give Today</span>
        <h2>Your Impact</h2>
              </div>

      <!-- 4 tier cards — equal height, buttons pinned to bottom -->
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; margin-top:2.5rem;">
        {tiers.map((tier, i) => (
          <div class="reveal" style={`transition-delay:${i*80}ms; background:#fff; border:1px solid #eee; padding:2rem; text-align:center; display:flex; flex-direction:column;`}>
            <div style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-size:2.5rem; font-weight:900; color:#35CCC0; margin-bottom:1rem;">{tier.amount}</div>
            <p style="font-family:'Raleway',sans-serif; font-size:0.85rem; color:#555; line-height:1.7; flex:1; margin-bottom:1.5rem;">{tier.desc}</p>
            <button onclick="openDonateModal()" class="btn-teal" style="width:100%; cursor:pointer; border:none;">
              Donate {tier.amount}
            </button>
          </div>
        ))}
      </div>

      <!-- Other amount -->
      <div style="text-align:center; margin-top:2rem;" class="reveal">
        <button onclick="openDonateModal()" style="background:none; border:2px solid #35CCC0; color:#35CCC0; font-family:'Raleway',sans-serif; font-weight:700; font-size:0.8rem; letter-spacing:0.1em; text-transform:uppercase; padding:0.75rem 2.5rem; cursor:pointer; transition:background 0.2s, color 0.2s;"
          onmouseover="this.style.background='#35CCC0'; this.style.color='#fff'"
          onmouseout="this.style.background='none'; this.style.color='#35CCC0'">
          Donate Other Amount
        </button>
      </div>
    </div>
  </section>

  <!-- MIGHTYCAUSE MODAL -->
  <div id="donate-modal-overlay" onclick="closeDonateModal()" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.65); z-index:2000; align-items:center; justify-content:center; padding:1rem;">
    <div onclick="event.stopPropagation()" style="background:#fff; width:100%; max-width:820px; max-height:90vh; overflow:hidden; position:relative; display:flex; flex-direction:column;">
      <!-- Modal header -->
      <div style="display:flex; align-items:center; justify-content:space-between; padding:1rem 1.5rem; border-bottom:1px solid #eee; flex-shrink:0;">
        <p style="font-family:'Raleway',sans-serif; font-weight:700; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.1em; color:#333; margin:0;">Secure Donation — Powered by MightyCause</p>
        <button onclick="closeDonateModal()" aria-label="Close" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:#999; line-height:1; padding:0;">&times;</button>
      </div>
      <!-- iframe -->
      <iframe
        id="donate-iframe"
        src=""
        data-src="https://www.mightycause.com/organization/Fdaaf/donate"
        width="100%"
        height="680"
        frameborder="0"
        scrolling="auto"
        title="Donate to FDAAF via MightyCause"
        style="display:block; border:none; flex:1;"
      ></iframe>
      <!-- Fallback -->
      <div style="padding:0.75rem 1.5rem; background:#f7f7f7; border-top:1px solid #eee; text-align:center; flex-shrink:0;">
        <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#999; margin:0;">
          Form not loading?
          <a href="https://www.mightycause.com/organization/Fdaaf" target="_blank" rel="noopener noreferrer" style="color:#35CCC0; text-decoration:none; font-weight:700;">Open MightyCause directly →</a>
        </p>
      </div>
    </div>
  </div>

  <script is:inline>
    function openDonateModal() {
      const overlay = document.getElementById('donate-modal-overlay');
      const iframe = document.getElementById('donate-iframe');
      // Lazy-load the iframe only when modal opens
      if (!iframe.src || iframe.src === window.location.href) {
        iframe.src = iframe.dataset.src;
      }
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeDonateModal() {
      document.getElementById('donate-modal-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDonateModal(); });
  </script>

  <style>
    @media (max-width: 700px) {
      div[style*="grid-template-columns:repeat(4,1fr)"] {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }
    @media (max-width: 420px) {
      div[style*="grid-template-columns:repeat(4,1fr)"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>

  <!-- LEGAL -->
  <section style="padding:2rem 2rem; background:#f7f7f7; border-top:1px solid #eee; text-align:center;">
    <div style="max-width:700px; margin:0 auto;" class="reveal">
      <p style="font-family:'Raleway',sans-serif; font-size:0.82rem; color:#999; line-height:1.8;">
        FDAAF is a registered 501(c)(3) nonprofit, Florida registration CH42912. All contributions are tax-deductible.<br />
        For sponsorships or custom giving, contact us at <a href="mailto:info@fdaaf.org" style="color:#35CCC0; text-decoration:none;">info@fdaaf.org</a> or <a href="https://twitter.com/FDAAFoundation" target="_blank" rel="noopener noreferrer" style="color:#35CCC0; text-decoration:none;">@FDAAFoundation</a>.
      </p>
    </div>
  </section>

</Layout>
