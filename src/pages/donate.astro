---
import Layout from '../layouts/Layout.astro';

const tiers = [
  { amount: '$25', desc: 'Funds accessibility features in our games, making them playable for more users.' },
  { amount: '$50', desc: "Supports volunteer training to build empathy events like 'Wheelchaired for a Day.'" },
  { amount: '$100', desc: 'Contributes to game development, bringing stories of empowerment to thousands.' },
  { amount: '$250+', desc: 'Enables sponsorship of new projects, amplifying voices in the disability community.' },
];
---

<Layout title="Donate" description="Support FDAAF — empowering the disability community through media and innovation. Your donation makes a difference.">

  <!-- PAGE HEADER -->
  <section class="bg-[#1a1a1a] py-20 text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-4xl sm:text-5xl font-display font-bold text-white mb-4">Donate to FDAAF</h1>
      <p class="text-white/60 text-lg">Your Donation Makes a Difference!</p>
    </div>
  </section>

  <!-- MISSION -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 reveal">
      <h2 class="text-3xl font-display font-bold text-[#1a1a1a] mb-6 text-center">
        Support FDAAF: Empowering the Disability Community Through Media and Innovation
      </h2>
      <p class="text-gray-600 leading-relaxed text-lg text-center mb-4">
        At the Florida Disability Access and Awareness Foundation (FDAAF), we're on a mission to create a more inclusive world. We develop interactive media, including video games and empathy-building experiences, that give a voice to people with disabilities.
      </p>
      <p class="text-gray-500 text-center text-sm">
        We accept every donation with gratitude, also offering sponsorship and investment possibilities. We don't believe in large corporate structures, excessive salaries and overhead. In fact, we rely mostly on volunteers and interns who appreciate the experience of driving social change. Still, we need your help to push our projects further.
      </p>
    </div>
  </section>

  <!-- TIERS -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-display font-bold text-[#1a1a1a] mb-12 text-center reveal">Your Impact</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {tiers.map((tier, i) => (
          <div class="reveal bg-white rounded-lg border border-gray-100 shadow-sm p-6 text-center flex flex-col" style={`transition-delay: ${i * 80}ms`}>
            <div class="text-4xl font-display font-bold text-[#27CCC0] mb-4">{tier.amount}</div>
            <p class="text-gray-600 text-sm leading-relaxed flex-1">{tier.desc}</p>
            <a
              href="https://www.mightycause.com/organization/Fdaaf"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary mt-5 text-center"
            >
              Donate {tier.amount}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MIGHTYCAUSE EMBED PLACEHOLDER -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center reveal">
      <h2 class="text-2xl font-display font-bold text-[#1a1a1a] mb-6">Donate Now</h2>
      <div class="img-placeholder h-48 w-full rounded-lg mb-6" style="background:#f0faf9; border-color:#27CCC0;">
        MightyCause Donation Form — Embed Here
      </div>
      <a
        href="https://www.mightycause.com/organization/Fdaaf"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Donate on MightyCause
      </a>
    </div>
  </section>

  <!-- LEGAL + CONTACT -->
  <section class="py-14 bg-gray-50 border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-6 text-center reveal">
      <p class="text-gray-500 text-sm leading-relaxed mb-2">
        FDAAF is a registered 501(c)(3) nonprofit, Florida registration CH42912. All contributions are tax-deductible.
      </p>
      <p class="text-gray-500 text-sm">
        For sponsorships or custom giving arrangements, contact us at{' '}
        <a href="mailto:info@fdaaf.org" class="text-[#27CCC0] hover:underline">info@fdaaf.org</a>
        {' '}or{' '}
        <a href="https://twitter.com/FDAAFoundation" target="_blank" rel="noopener noreferrer" class="text-[#27CCC0] hover:underline">@FDAAFoundation</a>.
      </p>
    </div>
  </section>

</Layout>
