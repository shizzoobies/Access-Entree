---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Donate" description="Support FDAAF — empowering the disability community through media and innovation. Your donation makes a difference.">

  <!-- HERO / PAGE TITLE -->
  <section style="padding:4rem 2rem 3rem; text-align:center; background:#fff; border-bottom:1px solid #eee;">
    <div style="max-width:800px; margin:0 auto;">
      <span style="display:inline-block; font-family:'Roboto',sans-serif; font-size:0.72rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:#27CCC0; padding:0.25rem 0.75rem; margin-bottom:1.25rem;">Make a Difference</span>
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3.2rem); color:#111; font-weight:700; margin:0 0 1rem;">Donate to FDAAF</h1>
      <p style="font-family:'Raleway',sans-serif; font-size:1.05rem; color:#444; line-height:1.8; max-width:640px; margin:0 auto;">
        Support FDAAF: Empowering the Disability Community Through Media and Innovation
      </p>
    </div>
  </section>

  <!-- MISSION + TIERS -->
  <section style="padding:3.5rem 2rem; background:#fafafa; border-bottom:1px solid #eee;">
    <div style="max-width:960px; margin:0 auto;">

      <div style="max-width:760px; margin:0 auto 2.5rem; text-align:center;" class="reveal">
        <h2 style="font-family:'Playfair Display',serif; font-size:1.7rem; color:#111; margin:0 0 1rem;">Your Donation Makes a Difference</h2>
        <p style="font-family:'Raleway',sans-serif; font-size:0.92rem; color:#555; line-height:1.85; margin-bottom:0.75rem;">
          At the Florida Disability Access and Awareness Foundation (FDAAF), we're on a mission to create a more inclusive world. We develop interactive media — including video games and empathy-building experiences — that give a voice to people with disabilities.
        </p>
        <p style="font-family:'Raleway',sans-serif; font-size:0.92rem; color:#555; line-height:1.85;">
          Every donation goes directly toward boosting awareness and accessibility for the disability community through media and technology.
        </p>
      </div>

      <!-- Tier buttons — clicking pre-fills the form amount -->
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem;" class="tier-grid reveal">
        <button class="tier-btn" data-amount="25">
          <div class="tier-amount">$25</div>
          <div class="tier-label">Funds accessibility features in our games</div>
        </button>
        <button class="tier-btn" data-amount="50">
          <div class="tier-amount">$50</div>
          <div class="tier-label">Supports volunteer training for empathy events</div>
        </button>
        <button class="tier-btn" data-amount="100">
          <div class="tier-amount">$100</div>
          <div class="tier-label">Contributes directly to game development</div>
        </button>
        <button class="tier-btn" data-amount="250">
          <div class="tier-amount">$250+</div>
          <div class="tier-label">Enables sponsorship of brand new projects</div>
        </button>
      </div>

    </div>
  </section>

  <!-- DONATION FORM WIDGET -->
  <section style="padding:3rem 2rem 4rem; background:#fff;" id="donate-form-section">
    <div style="max-width:960px; margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif; font-size:1.4rem; color:#111; text-align:center; margin:0 0 2rem;">Give Securely Online</h2>
      <div id="MC-donation-form"></div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#999; text-align:center; margin-top:1.5rem;">
        Form not loading?
        <a href="https://www.mightycause.com/organization/Fdaaf" target="_blank" rel="noopener noreferrer" style="color:#35CCC0; text-decoration:none; font-weight:700;">Open MightyCause directly →</a>
      </p>
    </div>
  </section>

  <!-- LEGAL -->
  <section style="padding:2rem; background:#f7f7f7; border-top:1px solid #eee; text-align:center;">
    <div style="max-width:700px; margin:0 auto;" class="reveal">
      <p style="font-family:'Raleway',sans-serif; font-size:0.82rem; color:#999; line-height:1.8;">
        FDAAF is a registered 501(c)(3) nonprofit, Florida registration CH42912. All contributions are tax-deductible.<br />
        For sponsorships or custom giving, contact us at <a href="mailto:info@fdaaf.org" style="color:#35CCC0; text-decoration:none;">info@fdaaf.org</a> or <a href="https://twitter.com/FDAAFoundation" target="_blank" rel="noopener noreferrer" style="color:#35CCC0; text-decoration:none;">@FDAAFoundation</a>.
      </p>
    </div>
  </section>


</Layout>

<style>
  .tier-btn {
    background: #fff;
    border: 2px solid #e8e8e8;
    border-radius: 8px;
    padding: 1.5rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .tier-btn:hover {
    border-color: #27CCC0;
    box-shadow: 0 4px 16px rgba(39,204,192,0.15);
    transform: translateY(-2px);
  }
  .tier-btn.active {
    border-color: #27CCC0;
    background: #f0fffe;
    box-shadow: 0 4px 20px rgba(39,204,192,0.25);
  }
  .tier-amount {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #27CCC0;
    margin-bottom: 0.5rem;
  }
  .tier-label {
    font-family: 'Raleway', sans-serif;
    font-size: 0.8rem;
    color: #555;
    line-height: 1.5;
  }
  .tier-btn.active .tier-label { color: #222; }
  @media (max-width: 720px) {
    .tier-grid { grid-template-columns: 1fr 1fr !important; }
  }
  @media (max-width: 480px) {
    .tier-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- Load MightyCause embed script inline so it runs immediately, then init form -->
<script is:inline>
  (function() {
    var BASE_URL = 'https://www.mightycause.com/forms/Fdaaf/?embed=embeddable_form';

    function initForm(amount) {
      var container = document.getElementById('MC-donation-form');
      if (!container) return;
      container.innerHTML = '';
      var url = amount ? BASE_URL + '&amount=' + amount : BASE_URL;
      window.MCForms.createEmbedForm({ elementID: 'MC-donation-form', url: url });
    }

    function waitForMCForms(amount, attempts) {
      attempts = attempts || 0;
      if (window.MCForms && window.MCForms.createEmbedForm) {
        initForm(amount);
      } else if (attempts < 50) {
        setTimeout(function() { waitForMCForms(amount, attempts + 1); }, 200);
      }
    }

    // Load the MightyCause script dynamically
    var script = document.createElement('script');
    script.src = 'https://downloads.mightycause.com/widgets/v1/embed.js';
    script.onload = function() { waitForMCForms(null, 0); };
    document.head.appendChild(script);

    // Expose for tier buttons
    window._mcSelectTier = function(btn, amount) {
      document.querySelectorAll('.tier-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      waitForMCForms(amount, 0);
      var section = document.getElementById('donate-form-section');
      if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    // Wire up tier buttons once DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.tier-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var amount = parseInt(btn.getAttribute('data-amount') || '0', 10);
          window._mcSelectTier(btn, amount);
        });
      });
    });
  })();
</script>
