---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Donate" description="Support FDAAF — empowering the disability community through media and innovation. Your donation makes a difference.">

  <!-- HERO -->
  <section style="position:relative; height:480px; overflow:hidden; display:flex; align-items:center; justify-content:center;">
    <img src="/images/donate-hero.jpg" alt="Two hands reaching toward each other in support" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;" />
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.6) 100%);"></div>
    <div style="position:relative; z-index:2; text-align:center; padding:0 2rem; max-width:800px;">
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3.4rem); color:#fff; font-weight:700; margin:0 0 1rem; text-shadow:0 2px 12px rgba(0,0,0,0.4);">Donate to FDAAF</h1>
      <p style="font-family:'Raleway',sans-serif; font-size:1.05rem; color:rgba(255,255,255,0.9); line-height:1.8; max-width:600px; margin:0 auto; text-shadow:0 1px 6px rgba(0,0,0,0.3);">
        Support FDAAF: Empowering the Disability Community Through Media and Innovation
      </p>
    </div>
  </section>

  <!-- MISSION -->
  <section style="padding:3.5rem 2rem; background:#fafafa; border-bottom:1px solid #eee;">
    <div style="max-width:800px; margin:0 auto;" class="reveal">

      <h2 style="font-family:'Playfair Display',serif; font-size:1.9rem; color:#111; margin:0 0 1.25rem;">Your Donation Makes a Difference!</h2>

      <p style="font-family:'Raleway',sans-serif; font-size:0.95rem; color:#444; line-height:1.9; margin-bottom:1rem;">
        At the Florida Disability Access and Awareness Foundation (FDAAF), we're on a mission to create a more inclusive world. We develop interactive media, including video games and empathy-building experiences, to promote understanding, empathy, and empowerment for people with disabilities. By challenging stereotypes and highlighting the strength of the human spirit, we give voices to those often overlooked—through stories built for, about, and by the disability community and their allies.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95rem; color:#444; line-height:1.9; margin-bottom:1rem;">
        Our work transforms perceptions and drives real change. Projects like <strong>Access: EnTree</strong>, a social-simulation game where players build accessible communities, and <strong>Changed</strong>, a choice-based adventure following a disabled military veteran, educate and inspire. Events such as <em>"Wheelchaired for a Day"</em> let participants experience accessibility challenges firsthand, fostering deeper empathy and advocacy.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95rem; color:#444; line-height:1.9; margin-bottom:2rem;">
        As a nonprofit with minimal overhead, we rely on dedicated volunteers, interns, and generous supporters like you to keep our initiatives going. Every donation helps us expand our reach, develop new games, and create more opportunities for positive storytelling.
      </p>

      <h3 style="font-family:'Playfair Display',serif; font-size:1.3rem; color:#111; margin:0 0 1rem;">How Your Gift Helps</h3>
      <ul style="font-family:'Raleway',sans-serif; font-size:0.95rem; color:#444; line-height:1.9; padding-left:1.25rem; margin-bottom:1.5rem;">
        <li><strong style="color:#27CCC0;">$25:</strong> Funds accessibility features in our games, making them playable for more users.</li>
        <li><strong style="color:#27CCC0;">$50:</strong> Supports volunteer training to build empathy events like "Wheelchaired for a Day."</li>
        <li><strong style="color:#27CCC0;">$100:</strong> Contributes to game development, bringing stories of empowerment to thousands.</li>
        <li><strong style="color:#27CCC0;">$250+:</strong> Enables sponsorship of new projects, amplifying voices in the disability community.</li>
      </ul>

      <p style="font-family:'Raleway',sans-serif; font-size:0.95rem; color:#444; line-height:1.9;">
        Whether it's a one-time gift or a monthly contribution, your support fuels innovation and inclusion. We also welcome sponsorships and investments — <a href="/contact/" style="color:#27CCC0; text-decoration:none; font-weight:600;">contact us to learn more!</a>
      </p>

    </div>
  </section>

  <!-- DONATION FORM WIDGET -->
  <section style="padding:3rem 2rem 4rem; background:#fff;" id="donate-form-section">
    <div style="max-width:960px; margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif; font-size:1.5rem; color:#111; text-align:center; margin:0 0 0.5rem;">Donate Today!</h2>
      <p style="font-family:'Raleway',sans-serif; font-size:0.92rem; color:#666; text-align:center; margin:0 0 2rem;">Ready to make an impact? Donate securely below. Your contribution is tax-deductible and we'll send a receipt for your records.</p>
      <div id="MC-donation-form"></div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#999; text-align:center; margin-top:1.5rem;">
        Form not loading?
        <a href="https://www.mightycause.com/organization/Fdaaf" target="_blank" rel="noopener noreferrer" style="color:#35CCC0; text-decoration:none; font-weight:700;">Open MightyCause directly →</a>
      </p>
    </div>
  </section>

  <!-- LEGAL -->
  <section style="padding:2.5rem 2rem; background:#f7f7f7; border-top:1px solid #eee; text-align:center;">
    <div style="max-width:760px; margin:0 auto;" class="reveal">
      <p style="font-family:'Raleway',sans-serif; font-size:0.88rem; color:#555; line-height:1.9; margin-bottom:1rem;">
        Thank you for standing with us. Together, we're building a world where disabilities don't define limits — they inspire possibilities.<br />
        For questions or custom giving options, reach out at <a href="mailto:info@fdaaf.org" style="color:#27CCC0; text-decoration:none; font-weight:600;">info@fdaaf.org</a> or follow us on X <a href="https://twitter.com/FDAAFoundation" target="_blank" rel="noopener noreferrer" style="color:#27CCC0; text-decoration:none; font-weight:600;">@FDAAFoundation</a>.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.78rem; color:#999; line-height:1.8;">
        FDAAF is a registered 501(c)(3) nonprofit, Florida registration CH42912. A copy of the official registration and financial information may be obtained from the Division of Consumer Services by calling toll-free (800-435-7352) within the state. Registration does not imply endorsement, approval, or recommendation by the state.
      </p>
    </div>
  </section>

</Layout>

<!-- Load MightyCause embed script inline so it runs immediately, then init form -->
<script is:inline>
  (function() {
    var BASE_URL = 'https://www.mightycause.com/forms/Fdaaf/?embed=embeddable_form';

    function initForm(amount) {
      var container = document.getElementById('MC-donation-form');
      if (!container) return;
      container.innerHTML = '';
      var url = amount ? BASE_URL + '&amount=' + amount : BASE_URL;
      window.MCForms.createEmbedForm({ elementID: 'MC-donation-form', url: url });
    }

    function waitForMCForms(amount, attempts) {
      attempts = attempts || 0;
      if (window.MCForms && window.MCForms.createEmbedForm) {
        initForm(amount);
      } else if (attempts < 50) {
        setTimeout(function() { waitForMCForms(amount, attempts + 1); }, 200);
      }
    }

    // Load the MightyCause script dynamically
    var script = document.createElement('script');
    script.src = 'https://downloads.mightycause.com/widgets/v1/embed.js';
    script.onload = function() { waitForMCForms(null, 0); };
    document.head.appendChild(script);
  })();
</script>
