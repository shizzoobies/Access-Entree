---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Ralph Strzalkowski',
    role: 'President',
    img: '/images/team-ralph.jpg',
    bio: "Born in Poland with cerebral palsy, Strzalkowski uses a wheelchair and initially felt limited by systemic barriers in his home country. He immigrated to America for a fresh start, becoming a lawyer and leveraging the Americans with Disabilities Act's opportunities. He founded FDAAF to address societal prejudice against people with disabilities, using media and technology to \"change how people think and feel about disabilities.\"",
  },
  {
    name: 'Zachary Taylor',
    role: 'Lead Developer',
    img: '/images/team-zachary.jpg',
    bio: "Taylor lost his hearing and balance in third grade after being misdiagnosed with flu — the actual cause was meningitis. A cochlear implant later aided his balance. He earned two electronics degrees from community college and a BS in Game Design from Full Sail University. Throughout his education, he advocated for accessibility features like subtitles and collaborated on adaptive controller design. He became FDAAF's first online Game Design graduate and continues developing accessible games with the organization.",
  },
  {
    name: 'Michael Bridges',
    role: 'Audio Engineer',
    img: '/images/team-michael.jpg',
    bio: "Bridges brings expertise in music recording, production, and sound design from Carnegie Mellon School of Music's certificate program. He founded SoundTruss Productions as lead engineer. Bridges joined FDAAF recognizing sound as a \"uniquely effective story telling tool,\" applying his skills to amplify the foundation's disability awareness mission.",
  },
  {
    name: 'Paul Brophy',
    role: 'Corporate Secretary and Treasurer',
    img: '/images/team-paul.png',
    bio: "An Irish emigrant to Florida, Brophy built an accessible bar in Gainesville emphasizing disability accommodation. He joined FDAAF in 2013 as Corporate Secretary and Treasurer. Since 2013, he has worked for Florida's Agency for People with Disabilities, combining personal advocacy with professional expertise in addressing systemic barriers.",
  },
];
---

<Layout title="About Us" description="Learn about the Florida Disability Access and Awareness Foundation — our mission, our team, and our commitment to the disability community.">

  <!-- HERO -->
  <section style="position:relative; height:420px; overflow:hidden; display:flex; align-items:center; justify-content:center;">
    <img src="/images/about-hero.jpg" alt="About FDAAF" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;" />
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%);"></div>
    <div style="position:relative; z-index:2; text-align:center; padding:0 2rem; max-width:800px;">
      <span style="display:inline-block; font-family:'Roboto',sans-serif; font-size:0.72rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:#27CCC0; padding:0.25rem 0.75rem; margin-bottom:1.25rem;">Who We Are</span>
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3.4rem); color:#fff; font-weight:700; margin:0; text-shadow:0 2px 12px rgba(0,0,0,0.4);">About Us</h1>
    </div>
  </section>

  <!-- MISSION -->
  <section style="padding:3.5rem 2rem; background:#fff; text-align:center;">
    <div style="max-width:800px; margin:0 auto;" class="reveal">
      <div class="section-heading">
        <span class="label">Who We Are</span>
        <h2>Acceptance. Accessibility.</h2>
              </div>
      <p style="font-family:'Raleway',sans-serif; font-size:1em; color:#333; line-height:1.8; margin-top:1.5rem;">
        The Florida Disability Access and Awareness Foundation creates media to promote empathy and empowerment for the disability community.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#555; line-height:1.8; margin-top:1rem;">
        Our ultimate goal is to help create an inclusive society where those with physical and intellectual challenges are treated with respect and their needs are understood and accommodated.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.85em; color:#999; margin-top:1rem;">
        FDAAF is a 501(c)(3) public charity. All contributions are tax-deductible.
      </p>
    </div>
  </section>

  <!-- TEAM -->
  <section style="padding:3.5rem 2rem; background:#f7f7f7;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal">
        <span class="label">The Team</span>
        <h2>Meet Our People</h2>
              </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:2rem; margin-top:2.5rem;">
        {team.map((member, i) => (
          <div class="reveal" style={`transition-delay:${i*80}ms; background:#fff; border:1px solid #eee; padding:1.75rem; text-align:center;`}>
            <img src={member.img} alt={member.name} style="width:100px; height:100px; border-radius:50%; margin:0 auto 1.25rem; display:block; object-fit:cover; border:3px solid #35CCC0;" />
            <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.9rem; text-transform:uppercase; letter-spacing:0.08em; color:#000; margin:0 0 0.25rem;">{member.name}</h3>
            <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#35CCC0; margin:0 0 1rem;">{member.role}</p>
            <p style="font-family:'Raleway',sans-serif; font-size:0.83rem; color:#555; line-height:1.7;">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GET INVOLVED -->
  <section style="padding:3rem 2rem; background:#fff; text-align:center;">
    <div style="max-width:600px; margin:0 auto;" class="reveal">
      <div class="section-heading">
        <span class="label">Join Us</span>
        <h2>Get Involved</h2>
              </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#333; line-height:1.8; margin-top:1.5rem;">
        Whether you want to volunteer, donate, or simply learn more, there's a place for you at FDAAF.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1.75rem;">
        <a href="/volunteer/" class="btn-teal">Volunteer</a>
        <a href="/donate/" class="btn-orange">Donate</a>
      </div>
    </div>
  </section>

</Layout>
