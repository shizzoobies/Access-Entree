---
import Layout from '../layouts/Layout.astro';

const departments = [
  'General Inquiries',
  'Sponsorships',
  'Volunteering',
  'Coding',
  'Donations',
  'Press',
  'Students and Interns',
  'Secretary (Paul Brophy)',
  'President (Ralph Strzalkowski)',
  'Webmaster (Jazzy Trafficano)',
  'Audio (Michael Bridges)',
  'Game Design (Zachary Taylor)',
];
---

<Layout title="Contact Us" description="Contact the Florida Disability Access and Awareness Foundation — learn more about how we promote inclusion through developing video games and using media.">

  <!-- HERO -->
  <section style="position:relative; height:420px; overflow:hidden; display:flex; align-items:center; justify-content:center;">
    <img src="/images/contact-hero.jpg" alt="Get in touch with FDAAF" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;" />
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%);"></div>
    <div style="position:relative; z-index:2; text-align:center; padding:0 2rem; max-width:800px;">
      <span style="display:inline-block; font-family:'Roboto',sans-serif; font-size:0.72rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:#27CCC0; padding:0.25rem 0.75rem; margin-bottom:1.25rem;">Reach Out</span>
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3.4rem); color:#fff; font-weight:700; margin:0; text-shadow:0 2px 12px rgba(0,0,0,0.4);">Contact Us</h1>
    </div>
  </section>

  <!-- CONTENT -->
  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:1100px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start;">

      <!-- Intro -->
      <div class="reveal">
        <div class="section-heading" style="text-align:left;">
          <span class="label">Reach Out</span>
          <h2>Get in touch</h2>
                  </div>
        <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#333; line-height:1.8; margin-top:1.5rem;">
          Contact us to learn more on how we promote inclusion through developing video games and using media. Get in touch to receive more information on how you can get involved with promoting disability awareness and accessibility.
        </p>
        <div style="margin-top:2rem; display:flex; flex-direction:column; gap:0.75rem;">
          <p style="font-family:'Raleway',sans-serif; font-size:0.85rem; color:#555;">
            <strong style="color:#000;">Email:</strong>&nbsp;
            <a href="mailto:info@fdaaf.org" style="color:#35CCC0; text-decoration:none;">info@fdaaf.org</a>
          </p>
          <div style="display:flex; gap:1.25rem;">
            <a href="https://twitter.com/FDAAFoundation" target="_blank" rel="noopener noreferrer"
              style="font-family:'Raleway',sans-serif; font-size:0.82rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#555; text-decoration:none;"
              onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#555'">Twitter</a>
            <a href="https://www.facebook.com/fdaaf" target="_blank" rel="noopener noreferrer"
              style="font-family:'Raleway',sans-serif; font-size:0.82rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#555; text-decoration:none;"
              onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#555'">Facebook</a>
            <a href="https://www.youtube.com/@fdaaf" target="_blank" rel="noopener noreferrer"
              style="font-family:'Raleway',sans-serif; font-size:0.82rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#555; text-decoration:none;"
              onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#555'">YouTube</a>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="reveal" style="transition-delay:100ms;">
        <h2 style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-weight:900; font-size:1.6rem; color:#000; margin-bottom:0.25rem;">Send us a message</h2>
        <p style="font-family:'Raleway',sans-serif; font-size:0.8rem; color:#999; margin-bottom:1.5rem;">All fields are required.</p>

        <form name="contact" method="POST" action="/contact/" style="display:flex; flex-direction:column; gap:1rem;">
          <div>
            <label for="name" style="display:block; font-family:'Raleway',sans-serif; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#333; margin-bottom:0.35rem;">Your Name</label>
            <input id="name" type="text" name="name" required />
          </div>
          <div>
            <label for="email" style="display:block; font-family:'Raleway',sans-serif; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#333; margin-bottom:0.35rem;">Your Email</label>
            <input id="email" type="email" name="email" required />
          </div>
          <div>
            <label for="subject" style="display:block; font-family:'Raleway',sans-serif; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#333; margin-bottom:0.35rem;">Subject</label>
            <input id="subject" type="text" name="subject" required />
          </div>
          <div>
            <label for="department" style="display:block; font-family:'Raleway',sans-serif; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#333; margin-bottom:0.35rem;">Department or Person You Would Like to Contact</label>
            <select id="department" name="department" required>
              <option value="" disabled selected>Select a department or person</option>
              {departments.map(d => <option value={d}>{d}</option>)}
            </select>
          </div>
          <div>
            <label for="message" style="display:block; font-family:'Raleway',sans-serif; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#333; margin-bottom:0.35rem;">Your Message</label>
            <textarea id="message" name="message" rows={5} required style="resize:vertical;"></textarea>
          </div>
          <button type="submit" class="btn-teal" style="align-self:flex-start; font-size:0.85rem; padding:0.85rem 2.5rem; text-transform:uppercase; letter-spacing:0.12em;">Send Message</button>
        </form>
      </div>
    </div>
  </section>

  <style>
    @media (max-width: 700px) {
      section > div[style*="grid-template-columns:1fr 1fr"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>

</Layout>
