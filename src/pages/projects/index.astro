---
import Layout from '../../layouts/Layout.astro';

const projects = [
  { title:'Access: Entree', tag:'In Development', desc:'A new mobile game that promotes accessibility awareness. Currently in development.', href:'/projects/access-entree/' },
  { title:'Changed', tag:'Video Game', desc:'A choice-based video game about a disabled military veteran.', href:'/projects/changed/' },
  { title:'Wheelchaired for a Day', tag:'Empathy Event', desc:'An empathy-building event where people experienced being in a wheelchair for a day.', href:'/projects/wheelchaired-for-a-day/' },
];
---

<Layout title="Projects" description="Explore FDAAF's projects — video games and interactive media that give people with disabilities a voice.">

  <section style="padding:3rem 1rem 2.5rem; text-align:center; background:#fff;">
    <div class="page-title-block">
      <span class="star">★</span>
      <h1>Our Projects</h1>
    </div>
  </section>

  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal">
        <span class="label">Projects</span>
        <h2>Great Ideas Done Right</h2>
        <span class="star">★</span>
      </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#555; line-height:1.8; text-align:center; max-width:680px; margin:1.5rem auto 0;">
        We develop video games and other interactive media to give people with disabilities a voice.
      </p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem; margin-top:2.5rem;">
        {projects.map((p, i) => (
          <div class="reveal" style={`transition-delay:${i*80}ms; border:1px solid #eee; overflow:hidden;`}>
            <div class="img-placeholder" style="height:200px; width:100%;">{p.title} Image</div>
            <div style="padding:1.5rem; text-align:center;">
              <p style="font-family:'Raleway',sans-serif; font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#35CCC0; margin-bottom:0.5rem;">{p.tag}</p>
              <h2 style="font-family:'Playfair Display',Georgia,serif; font-size:1.2rem; font-weight:700; color:#000; margin:0 0 0.75rem;">{p.title}</h2>
              <p style="font-family:'Raleway',sans-serif; font-size:0.85rem; color:#555; line-height:1.6; margin-bottom:1.25rem;">{p.desc}</p>
              <a href={p.href} style="color:#35CCC0; font-family:'Raleway',sans-serif; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; text-decoration:none;">Learn More →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
