---
import Layout from '../../layouts/Layout.astro';

const features = [
  { icon: '🌾', title: 'Farming', desc: 'Cultivate crops to sustain and grow your village.' },
  { icon: '🎣', title: 'Fishing', desc: 'Fish by the river and open seas with character Su.' },
  { icon: '🐄', title: 'Animal Husbandry', desc: 'Raise animals to support your growing community.' },
  { icon: '⚒️', title: 'Crafting', desc: 'Craft useful tools to improve life in the town.' },
  { icon: '📜', title: 'Quests', desc: 'Follow the narrative and complete missions that matter.' },
  { icon: '♿', title: 'Accessibility', desc: 'Improve infrastructure so all residents can thrive.' },
  { icon: '🤝', title: 'Recruitment', desc: 'New characters move in, bringing tools and knowledge.' },
  { icon: '🌳', title: 'Rukia Tree', desc: 'Revive the mystical Rukia tree at the heart of the town.' },
];

const team = [
  { name: 'Ralph Strzalkowski', role: 'President, FDAAF' },
  { name: 'Logan Cundiff', role: 'Game Director' },
  { name: 'Olivia Colomier', role: 'Game Producer' },
  { name: 'Alabhya Maheshwari', role: 'Lead Game Designer' },
  { name: 'Karl Truong', role: 'Programmer' },
  { name: 'Michael Bass', role: 'Level Designer' },
  { name: 'Martin Garcia', role: 'Level Designer' },
  { name: 'Kylon Tome', role: 'Art Team Co-Lead' },
  { name: 'Noah Gomes', role: 'Art Team Co-Lead' },
  { name: 'Torie Jones', role: '2D Artist' },
  { name: 'Kyle Sims', role: '3D Artist' },
  { name: 'Mariana Lobeto', role: 'Artist & Designer' },
  { name: 'Hannah Chung', role: 'UX Researcher' },
  { name: 'Robin Cabonita', role: 'UX Researcher' },
  { name: 'Madison Lysaght', role: 'UX/UI Designer' },
  { name: 'Sarah Anderson', role: 'Business Analyst' },
];
---

<Layout title="Access: Entree" description="Access: Entree — Forge an Accessible Community for All. A social-simulation RPG mobile game by FDAAF.">

  <!-- HERO — game purple branding -->
  <section style="border-top:8px solid #7a00df; border-bottom:8px solid #7a00df; padding:5rem 1rem 4rem; text-align:center; background:linear-gradient(135deg,#1a0033 0%,#3b006e 50%,#1a0033 100%); position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:url('/images/access-entree-1.png') center/cover; opacity:0.12;" aria-hidden="true"></div>
    <div style="position:relative; z-index:1; max-width:900px; margin:0 auto;">
      <p style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; color:#c084fc; margin-bottom:0.5rem;">In Development · Social-Sim RPG</p>
      <h1 style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-weight:900; font-size:clamp(2.2rem,6vw,4.5rem); color:#fff; margin:0 0 0.75rem; text-shadow:0 2px 16px rgba(122,0,223,0.6);">Access: Entree</h1>
      <p style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#c084fc; letter-spacing:0.05em; margin-bottom:1rem;">Forge an Accessible Community for All</p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; font-weight:500; color:#e2d4f7; line-height:1.8; max-width:640px; margin:0 auto 2rem;">
        A unique social-simulation roleplaying game where you move into a small town and help develop the community to be more accessible to its residents with disabilities.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" style="background:#7a00df; color:#fff; font-family:'Raleway',sans-serif; font-weight:700; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.1em; padding:0.85rem 2rem; text-decoration:none; border:2px solid #7a00df; transition:background 0.2s;"
          onmouseover="this.style.background='#5a00a8'; this.style.borderColor='#5a00a8'"
          onmouseout="this.style.background='#7a00df'; this.style.borderColor='#7a00df'">Visit Game Website</a>
        <a href="/donate/" style="background:transparent; color:#fff; font-family:'Raleway',sans-serif; font-weight:700; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.1em; padding:0.85rem 2rem; text-decoration:none; border:2px solid #fff; transition:background 0.2s;"
          onmouseover="this.style.background='rgba(255,255,255,0.15)'"
          onmouseout="this.style.background='transparent'">Support This Project</a>
      </div>
    </div>
  </section>

  <!-- ABOUT + VIDEO -->
  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:1000px; margin:0 auto;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:center;" class="reveal">
        <div>
          <div class="section-heading" style="text-align:left;">
            <span class="label" style="color:#7a00df; border-color:#7a00df;">About the Game</span>
            <h2>Build Your Town</h2>
          </div>
          <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#333; line-height:1.8; margin-top:1.5rem; margin-bottom:1rem;">
            Access: Entree is a one-of-a-kind social-simulation RPG for mobile where you move into a small, forgotten town and work to make it a welcoming place for everyone — including residents with disabilities.
          </p>
          <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#555; line-height:1.8; margin-bottom:1.5rem;">
            Farm, fish, craft, and build relationships with colorful characters as you transform the community. At the center of it all is the mystical Rukia tree — reviving it is the key to restoring the town.
          </p>
          <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" style="display:inline-block; background:#7a00df; color:#fff; font-family:'Raleway',sans-serif; font-weight:700; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.1em; padding:0.75rem 1.75rem; text-decoration:none;"
            onmouseover="this.style.background='#5a00a8'"
            onmouseout="this.style.background='#7a00df'">Start Building Today</a>
        </div>
        <div style="position:relative; width:100%; padding-top:56.25%; background:#000;">
          <iframe
            src="https://www.youtube.com/embed/d2GVGTKRJWk"
            title="Access: Entree gameplay trailer"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="position:absolute; inset:0; width:100%; height:100%; border:none; display:block;"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section style="padding:3.5rem 2rem; background:#f5f0ff;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#7a00df; border-color:#7a00df;">Gameplay</span>
        <h2>What You'll Do</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1.5rem; margin-top:2.5rem;">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay:${i*60}ms; background:#fff; padding:1.5rem; border-top:4px solid #7a00df; text-align:center;`}>
            <div style="font-size:2rem; margin-bottom:0.75rem;">{f.icon}</div>
            <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.08em; color:#3b006e; margin:0 0 0.5rem;">{f.title}</h3>
            <p style="font-family:'Raleway',sans-serif; font-size:0.82rem; color:#555; line-height:1.6; margin:0;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#7a00df; border-color:#7a00df;">Screenshots</span>
        <h2>Gameplay</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem; margin-top:2rem;">
        {[
          { src:'/images/access-entree-1.png', n:1 },
          { src:'/images/access-entree-2.png', n:2 },
          { src:'/images/access-entree-3.avif', n:3 },
        ].map(({ src, n }) => (
          <img src={src} alt={`Access: Entree screenshot ${n}`} class="reveal" style={`width:100%; height:200px; object-fit:cover; display:block; border:2px solid #f5f0ff; transition-delay:${(n-1)*80}ms;`} />
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTER SPOTLIGHT -->
  <section style="padding:3.5rem 2rem; background:#1a0033;">
    <div style="max-width:1000px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#c084fc; border-color:#7a00df; background:transparent;">Characters</span>
        <h2 style="color:#fff;">Meet the Residents</h2>
      </div>
      <div style="max-width:700px; margin:2rem auto 0; text-align:center;" class="reveal">
        <div style="background:rgba(122,0,223,0.2); border:1px solid #7a00df; padding:2rem;">
          <h3 style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-weight:900; font-size:1.5rem; color:#c084fc; margin:0 0 0.5rem;">Su</h3>
          <p style="font-family:'Raleway',sans-serif; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#7a00df; margin-bottom:1rem; background:#c084fc; display:inline-block; padding:0.2rem 0.75rem;">Fisherwoman</p>
          <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#e2d4f7; line-height:1.8;">
            A determined fisherwoman who navigates the beaches and open seas. Shipwrecked and battered by the sea's wrath in her youth, Su's fiery passion for sailing and fishing ignites her quest for the ocean's greatest challenge: capturing the mightiest fish beneath the waves.
          </p>
        </div>
        <p style="font-family:'Raleway',sans-serif; font-size:0.8rem; color:#9f7aea; margin-top:1.5rem;">
          More characters at <a href="https://accessentree.com/characters/" target="_blank" rel="noopener noreferrer" style="color:#c084fc; text-decoration:none; font-weight:700;">accessentree.com/characters →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section style="padding:3.5rem 2rem; background:#f5f0ff;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#7a00df; border-color:#7a00df;">The People Behind It</span>
        <h2>Our Team</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-top:2rem;">
        {team.map((member, i) => (
          <div class="reveal" style={`transition-delay:${i*40}ms; background:#fff; padding:1rem 1.25rem; border-left:3px solid #7a00df;`}>
            <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.82rem; color:#1a0033; margin:0 0 0.25rem;">{member.name}</h3>
            <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#7a00df; margin:0;">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:3.5rem 2rem; background:#7a00df; text-align:center;">
    <div style="max-width:700px; margin:0 auto;" class="reveal">
      <h2 style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-weight:900; font-size:clamp(1.6rem,4vw,2.5rem); color:#fff; margin:0 0 1rem;">Start Building Your Town Today</h2>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#e2d4f7; line-height:1.8; margin-bottom:2rem;">
        Access: Entree is developed by FDAAF — a volunteer-led nonprofit raising awareness for disability inclusion through media and technology.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" style="background:#fff; color:#7a00df; font-family:'Raleway',sans-serif; font-weight:700; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.1em; padding:0.85rem 2rem; text-decoration:none;"
          onmouseover="this.style.background='#e2d4f7'"
          onmouseout="this.style.background='#fff'">Visit accessentree.com</a>
        <a href="/donate/" style="background:transparent; color:#fff; font-family:'Raleway',sans-serif; font-weight:700; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.1em; padding:0.85rem 2rem; text-decoration:none; border:2px solid #fff;"
          onmouseover="this.style.background='rgba(255,255,255,0.15)'"
          onmouseout="this.style.background='transparent'">Donate to FDAAF</a>
      </div>
    </div>
  </section>

  <section style="padding:2rem 2rem; background:#fff; border-top:1px solid #eee;">
    <div style="max-width:1000px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
      <a href="/projects/" style="color:#7a00df; font-family:'Raleway',sans-serif; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; text-decoration:none;">← All Projects</a>
      <a href="/donate/" class="btn-orange">Support This Project</a>
    </div>
  </section>

  <style>
    @media (max-width:700px) {
      section > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns:1fr !important; }
    }
  </style>

</Layout>
