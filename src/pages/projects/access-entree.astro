---
import Layout from '../../layouts/Layout.astro';

const features = [
  { icon: '🌾', title: 'Farming', desc: 'Cultivate crops to sustain and grow your village.' },
  { icon: '🎣', title: 'Fishing', desc: 'Fish by the river and open seas with character Su.' },
  { icon: '🐄', title: 'Animal Husbandry', desc: 'Raise animals to support your growing community.' },
  { icon: '⚒️', title: 'Crafting', desc: 'Craft useful tools to improve life in the town.' },
  { icon: '📜', title: 'Quests', desc: 'Follow the narrative and complete missions that matter.' },
  { icon: '♿', title: 'Accessibility', desc: 'Improve infrastructure so all residents can thrive.' },
  { icon: '🤝', title: 'Recruitment', desc: 'New characters move in, bringing tools and knowledge.' },
  { icon: '🌳', title: 'Rukia Tree', desc: 'Revive the mystical Rukia tree at the heart of the town.' },
];

const team = [
  { name: 'Ralph Strzalkowski', role: 'President, FDAAF' },
  { name: 'Logan Cundiff', role: 'Game Director' },
  { name: 'Olivia Colomier', role: 'Game Producer' },
  { name: 'Alabhya Maheshwari', role: 'Lead Game Designer' },
  { name: 'Karl Truong', role: 'Programmer' },
  { name: 'Michael Bass', role: 'Level Designer' },
  { name: 'Martin Garcia', role: 'Level Designer' },
  { name: 'Kylon Tome', role: 'Art Team Co-Lead' },
  { name: 'Noah Gomes', role: 'Art Team Co-Lead' },
  { name: 'Torie Jones', role: '2D Artist' },
  { name: 'Kyle Sims', role: '3D Artist' },
  { name: 'Mariana Lobeto', role: 'Artist & Designer' },
  { name: 'Hannah Chung', role: 'UX Researcher' },
  { name: 'Robin Cabonita', role: 'UX Researcher' },
  { name: 'Madison Lysaght', role: 'UX/UI Designer' },
  { name: 'Sarah Anderson', role: 'Business Analyst' },
];

const gatherFeatures = features.slice(0, 4);
const buildFeatures = features.slice(4, 8);

const backerTiers = [
  {
    price: '$5',
    name: 'Rookie Builder',
    popular: false,
    rewards: [
      'Early bird price on PC and Switch copies of the game!',
      'Discord honor badge!',
    ],
  },
  {
    price: '$10',
    name: 'Rookie Builder+',
    popular: false,
    rewards: [
      'Digital wallpaper pack!',
      'Exclusive EnTree themed bed for your virtual home!',
      'Discord honor badge!',
    ],
  },
  {
    price: '$20',
    name: 'Junior Builder',
    popular: false,
    rewards: [
      'All previous rewards!',
      'Exclusive EnTree themed dresser for your virtual home!',
      'Help craft the world by joining our creative committee on Discord!',
    ],
  },
  {
    price: '$35',
    name: 'Junior Builder+',
    popular: false,
    rewards: [
      'All previous rewards!',
      'Donor exclusive Elder hat for your EnTree character!',
      'Access EnTree core sticker set!',
    ],
  },
  {
    price: '$50',
    name: 'Prodigy Builder',
    popular: true,
    rewards: [
      'All previous rewards!',
      'Free copy of Switch and PC game!',
      'Signed postcard from a team member!',
      'Exclusive character outfit!',
    ],
  },
  {
    price: '$65',
    name: 'Prodigy Builder+',
    popular: false,
    rewards: [
      'All previous rewards!',
      'Phonograph to change music in your EnTree home!',
      'Character sticker set!',
    ],
  },
  {
    price: '$100',
    name: 'Master Builder',
    popular: false,
    rewards: [
      'All previous rewards!',
      'Donor exclusive poster shipped to you (first 50 in this tier)!',
      'Donor exclusive outfit and skin for Rocket!',
    ],
  },
  {
    price: '$150',
    name: 'Grand Master Builder',
    popular: false,
    rewards: [
      'All previous rewards!',
      'Custom Access: EnTree hat shipped to you!',
      'Name in credits!',
    ],
  },
];

const backerStretchGoals = [
  {
    price: '$300',
    name: 'Elder Builder',
    rewards: [
      'Exclusive hand-made EnTree candle (first 50)!',
      'Choose a flower or plant to be added to the game in your honor!',
    ],
  },
  {
    price: '$500',
    name: 'Grand Elder Builder',
    rewards: [
      'Create an in-game character outfit with our art team (first 20)!',
      'Exclusive Access: EnTree Team jersey!',
    ],
  },
  {
    price: '$800',
    name: 'Grand Elder Builder Supreme',
    rewards: [
      'Alpha version access + feedback Discord channel!',
      'Create an in-game unique item with our art team (first 15)!',
    ],
  },
  {
    price: "$1,000",
    name: "Rukia's Servant",
    rewards: [
      'Create an in-game pet with our art team (first 10)!',
    ],
  },
];

const fundingGoals = [
  { amount: '$40K', label: 'Character Customization', desc: 'Create the character you want!' },
  { amount: '$60K', label: 'Build EnTree', desc: 'Build and accommodate to restore the village of EnTree — make this game a reality!' },
  { amount: '$70K', label: 'Production Credits', desc: 'Name added to production credits, join team discussions!' },
  { amount: '$80K', label: 'Cinematic Cutscenes', desc: 'Cinematic cutscenes + accessibility-focused Discord channel for new disabilities awareness!' },
];
---

<Layout
  title="Access: Entree Game — Kickstarter Coming Soon"
  description="Back the Kickstarter for Access: Entree — a social-simulation RPG where you build an accessible community. Farming, quests, and disability awareness in one unique mobile game."
  ogImage="/images/access-entree-og.jpg"
>

  <!-- 1. HERO -->
  <section style="border-top:8px solid #4a8c3f; border-bottom:8px solid #4a8c3f; padding:5rem 1rem 4.5rem; text-align:center; background:linear-gradient(160deg,#0a1407 0%,#162010 50%,#0a1407 100%); position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:url('/images/access-entree-1.png') center/cover; opacity:0.1;" aria-hidden="true"></div>
    <div style="position:relative; z-index:1; max-width:900px; margin:0 auto;">
      <div style="display:inline-flex; align-items:center; gap:0.45rem; background:#05ce78; color:#000; font-family:'Raleway',sans-serif; font-weight:900; font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; padding:0.3rem 0.9rem; border-radius:50px; margin-bottom:1.25rem;">
        <span style="display:inline-block; width:7px; height:7px; background:#000; border-radius:50%; animation:pulse 1.4s ease-in-out infinite;"></span>
        Launching Soon on Kickstarter
      </div>
      <h1 style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-weight:900; font-size:clamp(2.4rem,7vw,5rem); color:#e8f0e0; margin:0 0 0.75rem; text-shadow:0 2px 16px rgba(0,0,0,0.6); letter-spacing:-0.01em;">Access: EnTree</h1>
      <p style="font-family:'Raleway',sans-serif; font-size:clamp(1rem,2.5vw,1.25rem); font-weight:700; color:#7ab648; letter-spacing:0.02em; margin-bottom:1.25rem; line-height:1.5; max-width:620px; margin-left:auto; margin-right:auto;">
        Build and grow a village where everyone belongs in the first accessibility-themed social sim!
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; font-weight:500; color:#b8d4a8; line-height:1.8; max-width:560px; margin:0 auto 2rem;">
        Move into a forgotten small town and transform it into an inclusive, accessible community — through farming, crafting, quests, and connection.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-bottom:1.5rem;">
        <a href="https://www.kickstarter.com/projects/accessentree/access-entree" target="_blank" rel="noopener noreferrer" class="btn-kickstarter">Follow on Kickstarter</a>
        <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" class="btn-wood-outline">Visit Game Website</a>
      </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#5a8a50; letter-spacing:0.08em;">Mobile Games · Gainesville, FL · FDAAF</p>
    </div>
  </section>

  <!-- KICKSTARTER STRIP -->
  <section style="background:#05ce78; padding:1rem 2rem; text-align:center;">
    <div style="max-width:800px; margin:0 auto; display:flex; align-items:center; justify-content:center; gap:1.5rem; flex-wrap:wrap;">
      <p style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.88rem; letter-spacing:0.05em; color:#000; margin:0;">
        Help us launch — follow the project on Kickstarter and be the first to know when we go live.
      </p>
      <a href="https://www.kickstarter.com/projects/accessentree/access-entree" target="_blank" rel="noopener noreferrer" style="display:inline-block; background:#000; color:#fff; font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; letter-spacing:0.12em; text-transform:uppercase; padding:0.65rem 1.5rem; border-radius:4px; text-decoration:none; white-space:nowrap;">Follow on Kickstarter →</a>
    </div>
  </section>

  <!-- 2. ABOUT SECTION -->
  <section style="padding:3.5rem 2rem; background:#111f0b;">
    <div style="max-width:1000px; margin:0 auto;">
      <div class="about-grid reveal">
        <div>
          <div class="section-heading" style="text-align:left;">
            <span class="label" style="color:#7ab648; border-color:#4a8c3f;">About the Game</span>
            <h2 style="color:#e8f0e0;">About the Game</h2>
          </div>
          <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#b8d4a8; line-height:1.8; margin-top:1.5rem; margin-bottom:1rem;">
            Access: EnTree is a one-of-a-kind social-simulation RPG for mobile where you move into a small, forgotten town and work to make it a welcoming place for everyone — including residents with disabilities.
          </p>
          <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#8aad78; line-height:1.8; margin-bottom:1.5rem;">
            Farm, fish, craft, and build relationships with colorful characters as you transform the community. At the center of it all is the mystical Rukia tree — reviving it is the key to restoring the town.
          </p>
          <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" class="btn-wood">Start Building Today</a>
        </div>
        <div style="position:relative; width:100%; padding-top:56.25%; background:#000; border:3px solid #2d4a25;">
          <iframe
            src="https://www.youtube.com/embed/d2GVGTKRJWk"
            title="Access: Entree gameplay trailer"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="position:absolute; inset:0; width:100%; height:100%; border:none; display:block;"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. STORY / NARRATIVE SECTION -->
  <section style="padding:4.5rem 2rem; background:#0d1a09;">
    <div style="max-width:800px; margin:0 auto; text-align:center;" class="reveal">
      <div class="section-heading" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">The Story</span>
        <h2 style="color:#e8f0e0;">A Town That Forgot Its People</h2>
      </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#b8d4a8; line-height:1.9; margin:1.75rem 0 3rem;">
        EnTree was once a thriving village — but time, neglect, and a lack of understanding left many of its residents unable to fully participate in community life. When you arrive, you find a town full of heart but short on accessibility. Your mission: listen, learn, build, and restore. Every ramp built, every friendship formed, and every quest completed brings EnTree closer to becoming the inclusive home it was always meant to be.
      </p>
      <div class="stats-grid">
        <div class="stat-card reveal" style="transition-delay:0ms;">
          <div class="stat-number">16+</div>
          <div class="stat-label">Unique Characters</div>
        </div>
        <div class="stat-card reveal" style="transition-delay:80ms;">
          <div class="stat-number">8+</div>
          <div class="stat-label">Gameplay Activities</div>
        </div>
        <div class="stat-card reveal" style="transition-delay:160ms;">
          <div class="stat-number">20+</div>
          <div class="stat-label">Accessibility Quests</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. GAMEPLAY SECTION -->
  <section style="padding:3.5rem 2rem; background:#111f0b;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">Gameplay</span>
        <h2 style="color:#e8f0e0;">What You'll Do</h2>
      </div>

      <!-- Gather sub-section -->
      <div style="margin-top:3rem;">
        <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#05ce78; margin:0 0 1.25rem; padding-bottom:0.5rem; border-bottom:1px solid #2d4a25;">Gather</h3>
        <div class="features-grid">
          {gatherFeatures.map((f, i) => (
            <div class="reveal feature-card" style={`transition-delay:${i*60}ms;`}>
              <div style="font-size:2rem; margin-bottom:0.75rem;">{f.icon}</div>
              <h4 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.08em; color:#7ab648; margin:0 0 0.5rem;">{f.title}</h4>
              <p style="font-family:'Raleway',sans-serif; font-size:0.82rem; color:#8aad78; line-height:1.6; margin:0;">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Build sub-section -->
      <div style="margin-top:2.5rem;">
        <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#05ce78; margin:0 0 1.25rem; padding-bottom:0.5rem; border-bottom:1px solid #2d4a25;">Build</h3>
        <div class="features-grid">
          {buildFeatures.map((f, i) => (
            <div class="reveal feature-card" style={`transition-delay:${i*60}ms;`}>
              <div style="font-size:2rem; margin-bottom:0.75rem;">{f.icon}</div>
              <h4 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.08em; color:#7ab648; margin:0 0 0.5rem;">{f.title}</h4>
              <p style="font-family:'Raleway',sans-serif; font-size:0.82rem; color:#8aad78; line-height:1.6; margin:0;">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 5. SCREENSHOTS -->
  <section style="padding:3.5rem 2rem; background:#0d1a09;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">Screenshots</span>
        <h2 style="color:#e8f0e0;">Gameplay</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem; margin-top:2rem;">
        {[
          { src:'/images/access-entree-1.png', n:1 },
          { src:'/images/access-entree-2.png', n:2 },
          { src:'/images/access-entree-3.avif', n:3 },
        ].map(({ src, n }) => (
          <img src={src} alt={`Access: Entree screenshot ${n}`} class="reveal" style={`width:100%; height:200px; object-fit:cover; display:block; border:2px solid #2d4a25; transition-delay:${(n-1)*80}ms;`} />
        ))}
      </div>
    </div>
  </section>

  <!-- 6. CHARACTERS / RESIDENTS -->
  <section style="padding:4rem 2rem; background:#0a1407; text-align:center;">
    <div style="max-width:700px; margin:0 auto;" class="reveal">
      <div class="section-heading" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">The Residents</span>
        <h2 style="color:#e8f0e0;">Meet the Characters</h2>
      </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#8aad78; line-height:1.8; margin:1.5rem 0 2rem;">
        The town is full of unique residents — each with their own story, skills, and challenges. Get to know the people you'll be building alongside.
      </p>
      <button onclick="openResidentsModal()" class="btn-wood" style="font-size:1rem; padding:1rem 2.5rem;">Meet the Residents</button>
    </div>
  </section>

  <!-- RESIDENTS MODAL (iframe) -->
  <div id="residents-modal-overlay" onclick="closeResidentsModal()" style="display:none; position:fixed; inset:0; background:rgba(5,10,3,0.92); z-index:2000; align-items:center; justify-content:center; padding:0.5rem;">
    <div onclick="event.stopPropagation()" style="background:#0d1a09; border:2px solid #4a8c3f; width:95vw; height:92vh; display:flex; flex-direction:column; overflow:hidden; position:relative;">
      <div style="display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1.25rem; border-bottom:1px solid #2d4a25; flex-shrink:0;">
        <p style="font-family:'Raleway',sans-serif; font-weight:700; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.1em; color:#7ab648; margin:0;">Characters — Access: Entree</p>
        <div style="display:flex; align-items:center; gap:1rem;">
          <a href="https://accessentree.com/characters/" target="_blank" rel="noopener noreferrer" style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#4a8c3f; text-decoration:none; font-weight:700;">Open full page →</a>
          <button onclick="closeResidentsModal()" aria-label="Close" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:#4a8c3f; line-height:1; padding:0;">&times;</button>
        </div>
      </div>
      <iframe
        id="residents-iframe"
        src=""
        data-src="https://accessentree.com/characters/"
        width="100%"
        frameborder="0"
        title="Access: Entree Characters"
        style="display:block; border:none; flex:1; background:#fff; min-height:0;"
      ></iframe>
    </div>
  </div>

  <script is:inline>
    function openResidentsModal() {
      const overlay = document.getElementById('residents-modal-overlay');
      const iframe = document.getElementById('residents-iframe');
      if (!iframe.src || iframe.src === window.location.href) {
        iframe.src = iframe.dataset.src;
      }
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeResidentsModal() {
      document.getElementById('residents-modal-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
  </script>

  <!-- 7. REWARDS SECTION -->
  <section style="padding:4.5rem 2rem; background:linear-gradient(180deg,#0a1407 0%,#0d1a09 100%);">
    <div style="max-width:1100px; margin:0 auto;">

      <!-- Section header -->
      <div class="section-heading reveal" style="text-align:center; margin-bottom:3rem;">
        <span class="label" style="color:#05ce78; border-color:#05ce78;">Kickstarter Rewards</span>
        <h2 style="color:#e8f0e0;">Back the Kickstarter</h2>
        <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#8aad78; line-height:1.8; max-width:600px; margin:1rem auto 0;">
          Choose a tier that fits your support level. Every backer helps us build a more inclusive world — both in EnTree and beyond.
        </p>
      </div>

      <!-- A. BACKER TIERS -->
      <div style="margin-bottom:4rem;">
        <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#05ce78; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid #2d4a25;">Backer Tiers</h3>
        <div class="tiers-grid">
          {backerTiers.map((tier, i) => (
            <div class={`tier-card reveal${tier.popular ? ' tier-card--popular' : ''}`} style={`transition-delay:${i*50}ms;`}>
              {tier.popular && (
                <div class="popular-badge">Most Popular</div>
              )}
              <div class="price-badge">{tier.price}</div>
              <h4 class="tier-name">{tier.name}</h4>
              <ul class="tier-rewards">
                {tier.rewards.map(reward => (
                  <li>{reward}</li>
                ))}
              </ul>
              <div style="margin-top:auto; padding-top:1.25rem;">
                <a href="https://www.kickstarter.com/projects/accessentree/access-entree" target="_blank" rel="noopener noreferrer" class={tier.popular ? 'btn-kickstarter' : 'btn-wood-outline'} style="font-size:0.75rem; padding:0.65rem 1.25rem; display:inline-block;">Back at {tier.price}</a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- B. STRETCH GOALS -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start;" class="stretch-goals-grid">

        <!-- Backer Stretch Goals -->
        <div>
          <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#05ce78; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid #2d4a25;">Premium Backer Tiers</h3>
          <div style="display:flex; flex-direction:column; gap:0; border-left:2px solid #4a8c3f; padding-left:0; margin-left:0.5rem;">
            {backerStretchGoals.map((goal, i) => (
              <div class="stretch-item reveal" style={`transition-delay:${i*70}ms;`}>
                <div class="stretch-dot"></div>
                <div class="stretch-content">
                  <div class="stretch-price">{goal.price}</div>
                  <div class="stretch-name">{goal.name}</div>
                  <ul class="stretch-rewards">
                    {goal.rewards.map(r => (
                      <li>{r}</li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Funding Stretch Goals -->
        <div>
          <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#05ce78; margin:0 0 1.5rem; padding-bottom:0.5rem; border-bottom:1px solid #2d4a25;">Funding Milestones</h3>
          <p style="font-family:'Raleway',sans-serif; font-size:0.82em; color:#5a8a50; line-height:1.7; margin:0 0 1.5rem;">Features unlocked when we hit these funding goals:</p>
          <div style="display:flex; flex-direction:column; gap:0; border-left:2px solid #4a8c3f; padding-left:0; margin-left:0.5rem;">
            {fundingGoals.map((goal, i) => (
              <div class="stretch-item reveal" style={`transition-delay:${i*70}ms;`}>
                <div class="stretch-dot"></div>
                <div class="stretch-content">
                  <div class="stretch-price">{goal.amount}</div>
                  <div class="stretch-name">{goal.label}</div>
                  <p style="font-family:'Raleway',sans-serif; font-size:0.8rem; color:#8aad78; line-height:1.6; margin:0.25rem 0 0;">{goal.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- CTA inside rewards -->
      <div style="text-align:center; margin-top:3.5rem;" class="reveal">
        <a href="https://www.kickstarter.com/projects/accessentree/access-entree" target="_blank" rel="noopener noreferrer" class="btn-kickstarter" style="font-size:1rem; padding:1rem 2.5rem;">Back Access: EnTree on Kickstarter</a>
