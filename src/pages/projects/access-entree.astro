---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Access: Entree" description="Access: Entree is a unique social-simulation roleplaying game where the player moves into a small town and helps develop the community to be more accessible to its residents with disabilities.">

  <section style="padding:3rem 1rem 2.5rem; text-align:center; background:#fff;">
    <div class="page-title-block">
      <span class="star">★</span>
      <h1>Access: Entree</h1>
    </div>
  </section>

  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:1000px; margin:0 auto;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start;" class="reveal">
        <div>
          <div class="section-heading" style="text-align:left;">
            <span class="label">In Development</span>
            <h2>About the Game</h2>
            <span class="star" style="display:block; text-align:left;">★</span>
          </div>
          <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#333; line-height:1.8; margin-top:1.5rem; margin-bottom:1.25rem;">
            Access: Entree is a unique social-simulation roleplaying game where the player moves into a small town and helps develop the community to be more accessible to its residents with disabilities.
          </p>
          <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-top:1.5rem;">
            <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" class="btn-teal">Visit Game Website</a>
            <a href="/donate/" class="btn-orange">Support on Kickstarter</a>
          </div>
        </div>
        <div style="position:relative; width:100%; padding-top:56.25%; background:#000;">
          <iframe
            src="https://www.youtube.com/embed/d2GVGTKRJWk"
            title="Access: Entree gameplay trailer"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="position:absolute; inset:0; width:100%; height:100%; border:none; display:block;"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section style="padding:3.5rem 2rem; background:#f7f7f7;">
    <div style="max-width:1000px; margin:0 auto;">
      <div class="section-heading reveal">
        <span class="label">Screenshots</span>
        <h2>Gameplay</h2>
        <span class="star">★</span>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.5rem; margin-top:2rem;">
        {[
          { src:'/images/access-entree-1.png', n:1 },
          { src:'/images/access-entree-2.png', n:2 },
          { src:'/images/access-entree-3.avif', n:3 },
        ].map(({ src, n }) => (
          <img src={src} alt={`Access: Entree screenshot ${n}`} class="reveal" style={`width:100%; height:180px; object-fit:cover; display:block; transition-delay:${(n-1)*80}ms;`} />
        ))}
      </div>
    </div>
  </section>

  <section style="padding:2rem 2rem; background:#fff; border-top:1px solid #eee;">
    <div style="max-width:1000px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
      <a href="/projects/" style="color:#35CCC0; font-family:'Raleway',sans-serif; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; text-decoration:none;">← All Projects</a>
      <a href="/donate/" class="btn-orange">Support This Project</a>
    </div>
  </section>

  <style>
    @media (max-width:700px) {
      section > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns:1fr !important; }
    }
  </style>

</Layout>
