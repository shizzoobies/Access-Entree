---
import Layout from '../../layouts/Layout.astro';

const features = [
  { icon: '🌾', title: 'Farming', desc: 'Cultivate crops to sustain and grow your village.' },
  { icon: '🎣', title: 'Fishing', desc: 'Fish by the river and open seas with character Su.' },
  { icon: '🐄', title: 'Animal Husbandry', desc: 'Raise animals to support your growing community.' },
  { icon: '⚒️', title: 'Crafting', desc: 'Craft useful tools to improve life in the town.' },
  { icon: '📜', title: 'Quests', desc: 'Follow the narrative and complete missions that matter.' },
  { icon: '♿', title: 'Accessibility', desc: 'Improve infrastructure so all residents can thrive.' },
  { icon: '🤝', title: 'Recruitment', desc: 'New characters move in, bringing tools and knowledge.' },
  { icon: '🌳', title: 'Rukia Tree', desc: 'Revive the mystical Rukia tree at the heart of the town.' },
];

const team = [
  { name: 'Ralph Strzalkowski', role: 'President, FDAAF' },
  { name: 'Logan Cundiff', role: 'Game Director' },
  { name: 'Olivia Colomier', role: 'Game Producer' },
  { name: 'Alabhya Maheshwari', role: 'Lead Game Designer' },
  { name: 'Karl Truong', role: 'Programmer' },
  { name: 'Michael Bass', role: 'Level Designer' },
  { name: 'Martin Garcia', role: 'Level Designer' },
  { name: 'Kylon Tome', role: 'Art Team Co-Lead' },
  { name: 'Noah Gomes', role: 'Art Team Co-Lead' },
  { name: 'Torie Jones', role: '2D Artist' },
  { name: 'Kyle Sims', role: '3D Artist' },
  { name: 'Mariana Lobeto', role: 'Artist & Designer' },
  { name: 'Hannah Chung', role: 'UX Researcher' },
  { name: 'Robin Cabonita', role: 'UX Researcher' },
  { name: 'Madison Lysaght', role: 'UX/UI Designer' },
  { name: 'Sarah Anderson', role: 'Business Analyst' },
];
---

<Layout
  title="Access: Entree"
  description="Back the Kickstarter for Access: Entree — a social-simulation RPG where you build an accessible community. Farming, quests, and disability awareness in one unique mobile game."
  ogImage="/images/access-entree-og.jpg"
>

  <!-- HERO -->
  <section style="border-top:8px solid #4a8c3f; border-bottom:8px solid #4a8c3f; padding:5rem 1rem 4rem; text-align:center; background:linear-gradient(160deg,#0a1407 0%,#162010 50%,#0a1407 100%); position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:url('/images/access-entree-1.png') center/cover; opacity:0.1;" aria-hidden="true"></div>
    <div style="position:relative; z-index:1; max-width:900px; margin:0 auto;">
      <p style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; color:#7ab648; margin-bottom:0.5rem;">In Development · Social-Sim RPG</p>
      <h1 style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-weight:900; font-size:clamp(2.2rem,6vw,4.5rem); color:#e8f0e0; margin:0 0 0.75rem; text-shadow:0 2px 16px rgba(0,0,0,0.6);">Access: Entree</h1>
      <p style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#7ab648; letter-spacing:0.05em; margin-bottom:1rem;">Forge an Accessible Community for All</p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; font-weight:500; color:#b8d4a8; line-height:1.8; max-width:640px; margin:0 auto 2rem;">
        A unique social-simulation roleplaying game where you move into a small town and help develop the community to be more accessible to its residents with disabilities.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" class="btn-wood">Visit Game Website</a>
        <a href="/donate/" class="btn-wood-outline">Support This Project</a>
      </div>
    </div>
  </section>

  <!-- ABOUT + VIDEO -->
  <section style="padding:3.5rem 2rem; background:#111f0b;">
    <div style="max-width:1000px; margin:0 auto;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:center;" class="reveal">
        <div>
          <div class="section-heading" style="text-align:left;">
            <span class="label" style="color:#7ab648; border-color:#4a8c3f;">About the Game</span>
            <h2 style="color:#e8f0e0;">Build Your Town</h2>
          </div>
          <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#b8d4a8; line-height:1.8; margin-top:1.5rem; margin-bottom:1rem;">
            Access: Entree is a one-of-a-kind social-simulation RPG for mobile where you move into a small, forgotten town and work to make it a welcoming place for everyone — including residents with disabilities.
          </p>
          <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#8aad78; line-height:1.8; margin-bottom:1.5rem;">
            Farm, fish, craft, and build relationships with colorful characters as you transform the community. At the center of it all is the mystical Rukia tree — reviving it is the key to restoring the town.
          </p>
          <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" class="btn-wood">Start Building Today</a>
        </div>
        <div style="position:relative; width:100%; padding-top:56.25%; background:#000; border:3px solid #2d4a25;">
          <iframe
            src="https://www.youtube.com/embed/d2GVGTKRJWk"
            title="Access: Entree gameplay trailer"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="position:absolute; inset:0; width:100%; height:100%; border:none; display:block;"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section style="padding:3.5rem 2rem; background:#0d1a09;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">Gameplay</span>
        <h2 style="color:#e8f0e0;">What You'll Do</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1.5rem; margin-top:2.5rem;">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay:${i*60}ms; background:#162010; padding:1.5rem; border-top:4px solid #4a8c3f; text-align:center; border-left:1px solid #2d4a25; border-right:1px solid #2d4a25; border-bottom:1px solid #2d4a25;`}>
            <div style="font-size:2rem; margin-bottom:0.75rem;">{f.icon}</div>
            <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.08em; color:#7ab648; margin:0 0 0.5rem;">{f.title}</h3>
            <p style="font-family:'Raleway',sans-serif; font-size:0.82rem; color:#8aad78; line-height:1.6; margin:0;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section style="padding:3.5rem 2rem; background:#111f0b;">
    <div style="max-width:1100px; margin:0 auto;">
      <div class="section-heading reveal" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">Screenshots</span>
        <h2 style="color:#e8f0e0;">Gameplay</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem; margin-top:2rem;">
        {[
          { src:'/images/access-entree-1.png', n:1 },
          { src:'/images/access-entree-2.png', n:2 },
          { src:'/images/access-entree-3.avif', n:3 },
        ].map(({ src, n }) => (
          <img src={src} alt={`Access: Entree screenshot ${n}`} class="reveal" style={`width:100%; height:200px; object-fit:cover; display:block; border:2px solid #2d4a25; transition-delay:${(n-1)*80}ms;`} />
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERS -->
  <section style="padding:4rem 2rem; background:#0a1407; text-align:center;">
    <div style="max-width:700px; margin:0 auto;" class="reveal">
      <div class="section-heading" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">The Residents</span>
        <h2 style="color:#e8f0e0;">Meet the Characters</h2>
      </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#8aad78; line-height:1.8; margin:1.5rem 0 2rem;">
        The town is full of unique residents — each with their own story, skills, and challenges. Get to know the people you'll be building alongside.
      </p>
      <button onclick="openResidentsModal()" class="btn-wood" style="font-size:1rem; padding:1rem 2.5rem;">Meet the Residents</button>
    </div>
  </section>

  <!-- RESIDENTS MODAL (iframe) -->
  <div id="residents-modal-overlay" onclick="closeResidentsModal()" style="display:none; position:fixed; inset:0; background:rgba(5,10,3,0.92); z-index:2000; align-items:center; justify-content:center; padding:0.5rem;">
    <div onclick="event.stopPropagation()" style="background:#0d1a09; border:2px solid #4a8c3f; width:95vw; height:92vh; display:flex; flex-direction:column; overflow:hidden; position:relative;">
      <div style="display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1.25rem; border-bottom:1px solid #2d4a25; flex-shrink:0;">
        <p style="font-family:'Raleway',sans-serif; font-weight:700; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.1em; color:#7ab648; margin:0;">Characters — Access: Entree</p>
        <div style="display:flex; align-items:center; gap:1rem;">
          <a href="https://accessentree.com/characters/" target="_blank" rel="noopener noreferrer" style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#4a8c3f; text-decoration:none; font-weight:700;">Open full page →</a>
          <button onclick="closeResidentsModal()" aria-label="Close" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:#4a8c3f; line-height:1; padding:0;">&times;</button>
        </div>
      </div>
      <iframe
        id="residents-iframe"
        src=""
        data-src="https://accessentree.com/characters/"
        width="100%"
        frameborder="0"
        title="Access: Entree Characters"
        style="display:block; border:none; flex:1; background:#fff; min-height:0;"
      ></iframe>
    </div>
  </div>

  <script is:inline>
    function openResidentsModal() {
      const overlay = document.getElementById('residents-modal-overlay');
      const iframe = document.getElementById('residents-iframe');
      if (!iframe.src || iframe.src === window.location.href) {
        iframe.src = iframe.dataset.src;
      }
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeResidentsModal() {
      document.getElementById('residents-modal-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
  </script>

  <!-- TEAM -->
  <section style="padding:4rem 2rem; background:#111f0b; text-align:center;">
    <div style="max-width:700px; margin:0 auto;" class="reveal">
      <div class="section-heading" style="text-align:center;">
        <span class="label" style="color:#7ab648; border-color:#4a8c3f;">The People Behind It</span>
        <h2 style="color:#e8f0e0;">Our Team</h2>
      </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#8aad78; line-height:1.8; margin:1.5rem 0 2rem;">
        Access: Entree is built by a passionate volunteer team dedicated to disability inclusion through game development.
      </p>
      <button onclick="openTeamModal()" class="btn-wood" style="font-size:1rem; padding:1rem 2.5rem;">Meet the Team</button>
    </div>
  </section>

  <!-- TEAM MODAL -->
  <div id="team-modal-overlay" onclick="closeTeamModal()" style="display:none; position:fixed; inset:0; background:rgba(5,10,3,0.92); z-index:2000; align-items:center; justify-content:center; padding:0.5rem;">
    <div onclick="event.stopPropagation()" style="background:#0d1a09; border:2px solid #4a8c3f; width:95vw; height:92vh; display:flex; flex-direction:column; overflow:hidden; position:relative;">
      <div style="display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1.25rem; border-bottom:1px solid #2d4a25; flex-shrink:0;">
        <p style="font-family:'Raleway',sans-serif; font-weight:700; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.1em; color:#7ab648; margin:0;">Access: Entree Team</p>
        <div style="display:flex; align-items:center; gap:1rem;">
          <a href="https://accessentree.com/team/" target="_blank" rel="noopener noreferrer" style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#4a8c3f; text-decoration:none; font-weight:700;">Open full page →</a>
          <button onclick="closeTeamModal()" aria-label="Close" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:#4a8c3f; line-height:1; padding:0;">&times;</button>
        </div>
      </div>
      <iframe
        id="team-iframe"
        src=""
        data-src="https://accessentree.com/team/"
        width="100%"
        frameborder="0"
        title="Access: Entree Team"
        style="display:block; border:none; flex:1; background:#fff; min-height:0;"
      ></iframe>
    </div>
  </div>

  <script is:inline>
    function openTeamModal() {
      const iframe = document.getElementById('team-iframe');
      if (!iframe.src || iframe.src === window.location.href) {
        iframe.src = iframe.dataset.src;
      }
      document.getElementById('team-modal-overlay').style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeTeamModal() {
      document.getElementById('team-modal-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') { closeResidentsModal(); closeTeamModal(); }
    });
  </script>

  <!-- CTA -->
  <section style="padding:4rem 2rem; background:#0d1a09; text-align:center; border-top:4px solid #4a8c3f;">
    <div style="max-width:700px; margin:0 auto;" class="reveal">
      <h2 style="font-family:'Playfair Display',Georgia,serif; font-style:italic; font-weight:900; font-size:clamp(1.6rem,4vw,2.5rem); color:#e8f0e0; margin:0 0 1rem;">Start Building Your Town Today</h2>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#8aad78; line-height:1.8; margin-bottom:2rem;">
        Access: Entree is developed by FDAAF — a volunteer-led nonprofit raising awareness for disability inclusion through media and technology.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" class="btn-wood">Visit accessentree.com</a>
        <a href="/donate/" class="btn-wood-outline">Donate to FDAAF</a>
      </div>
    </div>
  </section>

  <section style="padding:2rem 2rem; background:#0a1407; border-top:1px solid #2d4a25;">
    <div style="max-width:1000px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
      <a href="/projects/" style="color:#4a8c3f; font-family:'Raleway',sans-serif; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; text-decoration:none;">← All Projects</a>
      <a href="/donate/" class="btn-wood">Support This Project</a>
    </div>
  </section>

  <style>
    .btn-wood {
      display: inline-block;
      position: relative;
      /* Wood grain: fine horizontal lines + main log color */
      background:
        repeating-linear-gradient(
          179deg,
          transparent 0px, transparent 4px,
          rgba(0,0,0,0.06) 4px, rgba(0,0,0,0.06) 5px
        ),
        repeating-linear-gradient(
          181deg,
          transparent 0px, transparent 11px,
          rgba(255,255,255,0.04) 11px, rgba(255,255,255,0.04) 12px
        ),
        /* Log end-cap glow on left & right edges */
        radial-gradient(ellipse 28px 80% at 0% 50%, rgba(210,140,70,0.55) 0%, transparent 100%),
        radial-gradient(ellipse 28px 80% at 100% 50%, rgba(210,140,70,0.55) 0%, transparent 100%),
        /* Main wood tones */
        linear-gradient(180deg, #c07840 0%, #8a4e22 25%, #7a3e18 55%, #8a4e22 80%, #5c2e10 100%);
      color: #f0d8b0;
      font-family: 'Raleway', sans-serif;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.13em;
      padding: 0.9rem 2.5rem;
      text-decoration: none;
      border-radius: 10px;
      border: 1px solid #3a1e08;
      border-top: 1px solid #c8885a;
      border-bottom: 4px solid #2a1005;
      box-shadow:
        0 6px 22px rgba(0,0,0,0.5),
        0 2px 4px rgba(0,0,0,0.3),
        inset 0 1px 0 rgba(255,220,140,0.2),
        inset 0 -1px 0 rgba(0,0,0,0.25);
      text-shadow: 0 1px 3px rgba(0,0,0,0.7);
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .btn-wood:hover {
      filter: brightness(1.12);
      transform: translateY(-2px);
      box-shadow:
        0 10px 30px rgba(0,0,0,0.55),
        0 3px 6px rgba(0,0,0,0.3),
        inset 0 1px 0 rgba(255,220,140,0.25),
        inset 0 -1px 0 rgba(0,0,0,0.2);
      color: #f0d8b0;
    }
    .btn-wood:active {
      transform: translateY(1px);
      border-bottom-width: 1px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.4);
    }
    .btn-wood-outline {
      display: inline-block;
      background: transparent;
      color: #a8d898;
      font-family: 'Raleway', sans-serif;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.13em;
      padding: 0.88rem 2.25rem;
      text-decoration: none;
      border: 2px solid #4a8c3f;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.25s ease;
    }
    .btn-wood-outline:hover {
      background: #4a8c3f;
      color: #fff;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(74,140,63,0.4);
    }
    @media (max-width:700px) {
      section > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns:1fr !important; }
    }
  </style>

</Layout>
