---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Access: Entree" description="Access: Entree is a unique social-simulation roleplaying game where the player moves into a small town and helps develop the community to be more accessible to its residents with disabilities.">

  <!-- PAGE HEADER -->
  <section class="bg-[#1a1a1a] py-20 text-center">
    <div class="max-w-3xl mx-auto px-6">
      <span class="text-[#27CCC0] text-xs font-semibold uppercase tracking-widest mb-4 block">In Development</span>
      <h1 class="text-4xl sm:text-5xl font-display font-bold text-white mb-4">Access: Entree</h1>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div class="reveal">
          <h2 class="text-2xl font-display font-bold text-[#1a1a1a] mb-5">About the Game</h2>
          <p class="text-gray-600 leading-relaxed text-lg mb-6">
            Access: Entree is a unique social-simulation roleplaying game where the player moves into a small town and helps develop the community to be more accessible to its residents with disabilities.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="https://accessentree.com" target="_blank" rel="noopener noreferrer" class="btn-primary">Visit Game Website</a>
            <a href="#" class="btn-orange">Support on Kickstarter</a>
          </div>
        </div>
        <div class="reveal img-placeholder h-72 w-full rounded-lg" style="transition-delay:100ms">Access: Entree Screenshot</div>
      </div>
    </div>
  </section>

  <!-- GAMEPLAY -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6 reveal">
      <h2 class="text-3xl font-display font-bold text-[#1a1a1a] mb-6 text-center">Gameplay</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <div class="img-placeholder h-48 w-full rounded-lg mb-4">Gameplay Screenshot 1</div>
        </div>
        <div>
          <div class="img-placeholder h-48 w-full rounded-lg mb-4">Gameplay Screenshot 2</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BACK -->
  <section class="py-10 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-6 flex justify-between items-center">
      <a href="/projects/" class="text-[#27CCC0] hover:underline text-sm font-semibold">&larr; All Projects</a>
      <a href="/donate/" class="btn-orange">Support This Project</a>
    </div>
  </section>

</Layout>
