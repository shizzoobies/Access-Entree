---
import Layout from '../../layouts/Layout.astro';

const characters = [
  { name:'Jesse White', role:'The main character of Changed', img:'/images/changed-jesse.png' },
  { name:'Jessica White', role:"Jesse's sister", img:'/images/changed-jessica.png' },
  { name:'Curtis Devine', role:"Jesse's friend from the military", img:'/images/changed-curtis.png' },
];

const environments = [
  { label:"Jesse's House (Interior)", img:'/images/changed-env-interior-1.jpg' },
  { label:"Jesse's House (Interior)", img:'/images/changed-env-interior-2.jpg' },
  { label:"Jesse's House (Exterior)", img:'/images/changed-env-exterior.jpg' },
  { label:"Hospital Room", img:'/images/changed-env-hospital.jpg' },
  { label:"Trailer Park", img:'/images/changed-env-trailerpark.jpg' },
];
---

<Layout title="Changed" description="Changed is the world's first choice-based video game about a character who finds himself in a wheelchair after an accident.">

  <!-- HERO -->
  <section style="position:relative; height:420px; overflow:hidden; display:flex; align-items:center; justify-content:center;">
    <img src="/images/changed-hero.jpg" alt="Changed — a choice-based video game" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;" />
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.65) 100%);"></div>
    <div style="position:relative; z-index:2; text-align:center; padding:0 2rem; max-width:800px;">
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3.4rem); color:#fff; font-weight:700; margin:0; text-shadow:0 2px 12px rgba(0,0,0,0.4);">Changed</h1>
    </div>
  </section>

  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:700px; margin:0 auto; text-align:center;" class="reveal">
      <img src="/images/project-changed.jpg" alt="Changed video game" style="width:100%; display:block; margin:0 auto 2rem;" />
      <div class="section-heading">
        <span class="label">Video Game</span>
        <h2>About the Game</h2>
      </div>
      <p style="font-family:'Raleway',sans-serif; font-size:0.95em; color:#333; line-height:1.8; margin-top:1.5rem; margin-bottom:1rem;">
        Changed is the world's first choice-based video game about a character who finds himself in a wheelchair after an accident.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#555; line-height:1.8; margin-bottom:1rem;">
        On his journey he is faced with numerous difficult situations. How he decides to tackle these situations develops his personality and advances the plot of the game.
      </p>
      <p style="font-family:'Raleway',sans-serif; font-size:0.9em; color:#555; line-height:1.8; margin-bottom:1.5rem;">
        We are currently producing a two-scene demo for the game.
      </p>
      <a href="/donate/" class="btn-teal">Support This Project</a>
    </div>
  </section>

  <section style="padding:3.5rem 2rem; background:#f7f7f7;">
    <div style="max-width:1000px; margin:0 auto;">
      <div class="section-heading reveal">
        <span class="label">Meet the Cast</span>
        <h2>Characters</h2>
              </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:2rem; margin-top:2rem;">
        {characters.map((c, i) => (
          <div class="reveal" style={`transition-delay:${i*80}ms; text-align:center;`}>
            <img src={c.img} alt={`${c.name} character art`} style="width:100%; height:180px; object-fit:cover; display:block; margin-bottom:1rem;" />
            <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.9rem; text-transform:uppercase; letter-spacing:0.06em; color:#000; margin:0 0 0.25rem;">{c.name}</h3>
            <p style="font-family:'Raleway',sans-serif; font-size:0.8rem; color:#35CCC0;">{c.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="padding:3.5rem 2rem; background:#fff;">
    <div style="max-width:1000px; margin:0 auto;">
      <div class="section-heading reveal">
        <span class="label">Concept Art</span>
        <h2>Environments</h2>
              </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:1rem; margin-top:2rem;">
        {environments.map((env, i) => (
          <div class="reveal" style={`transition-delay:${i*60}ms;`}>
            <img src={env.img} alt={env.label} style="width:100%; height:140px; object-fit:cover; display:block; margin-bottom:0.5rem;" />
            <p style="font-family:'Raleway',sans-serif; font-size:0.75rem; color:#777; text-align:center;">{env.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="padding:2rem 2rem; background:#f7f7f7; border-top:1px solid #eee;">
    <div style="max-width:1000px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
      <a href="/projects/" style="color:#35CCC0; font-family:'Raleway',sans-serif; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; text-decoration:none;">← All Projects</a>
      <a href="/donate/" class="btn-orange">Support This Project</a>
    </div>
  </section>

  <style>
    @media (max-width:700px) {
      section > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns:1fr !important; }
    }
  </style>

</Layout>
