---
const year = new Date().getFullYear();
---

<footer style="background:#7f1416; color:#ccc; font-family:'Raleway',sans-serif; font-size:0.85rem;">
  <div style="max-width:1400px; margin:0 auto; padding:3rem 2rem 2rem; display:grid; grid-template-columns:repeat(auto-fit, minmax(200px,1fr)); gap:2rem;">

    <!-- Column 1: Logo + About -->
    <div>
      <div class="img-placeholder" style="width:120px; height:40px; margin-bottom:1rem; background:#5a0e10; border-color:#a03030; color:#ccc; font-size:0.6rem; border-radius:2px;">Logo</div>
      <p style="color:#ccc; line-height:1.7; font-size:0.8rem;">
        Florida Disability Access and Awareness Foundation — a 501(c)(3) nonprofit using media to promote empathy and empowerment for the disability community.
      </p>
    </div>

    <!-- Column 2: Navigation -->
    <div>
      <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; color:#7f1416; background:#ccc; display:inline-block; padding:0.2rem 0.5rem; margin-bottom:1rem;">Navigate</h3>
      <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem;">
        {[
          { label: 'Home', href: '/' },
          { label: 'Projects', href: '/projects/' },
          { label: 'About Us', href: '/about/' },
          { label: 'Volunteer', href: '/volunteer/' },
          { label: 'Donate', href: '/donate/' },
          { label: 'Contact', href: '/contact/' },
        ].map(link => (
          <li>
            <a href={link.href} style="color:#ccc; text-decoration:none; font-size:0.82rem;"
              onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#ccc'">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 3: Social -->
    <div>
      <h3 style="font-family:'Raleway',sans-serif; font-weight:900; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; color:#7f1416; background:#ccc; display:inline-block; padding:0.2rem 0.5rem; margin-bottom:1rem;">Follow Us</h3>
      <div style="display:flex; gap:1rem; margin-bottom:1rem;">
        <a href="https://twitter.com/FDAAFoundation" target="_blank" rel="noopener noreferrer" aria-label="Twitter" style="color:#ccc;"
          onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#ccc'">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.facebook.com/fdaaf" target="_blank" rel="noopener noreferrer" aria-label="Facebook" style="color:#ccc;"
          onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#ccc'">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
        </a>
        <a href="https://www.youtube.com/@fdaaf" target="_blank" rel="noopener noreferrer" aria-label="YouTube" style="color:#ccc;"
          onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#ccc'">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
      <p style="color:#ccc; font-size:0.8rem;">
        <a href="mailto:info@fdaaf.org" style="color:#ccc; text-decoration:none;"
          onmouseover="this.style.color='#27CCC0'" onmouseout="this.style.color='#ccc'">info@fdaaf.org</a>
      </p>
    </div>

  </div>

  <!-- Bottom bar -->
  <div style="border-top:1px solid rgba(255,255,255,0.1); margin-top:1rem;">
    <div style="max-width:1400px; margin:0 auto; padding:1rem 2rem; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:0.5rem; color:rgba(255,255,255,0.4); font-size:0.75rem;">
      <p>&copy; {year} FDAAF: Florida Disability Access And Awareness Foundation</p>
      <p>501(c)(3) Public Charity · FL Reg. CH42912</p>
    </div>
  </div>
</footer>
