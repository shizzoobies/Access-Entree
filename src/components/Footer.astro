---
const year = new Date().getFullYear();
---

<footer class="bg-[#7f1416] text-white">
  <div class="max-w-6xl mx-auto px-6 py-14 grid grid-cols-1 md:grid-cols-3 gap-10">

    <!-- Brand -->
    <div>
      <img src="/images/logo.png" alt="FDAAF Logo" class="h-12 w-auto mb-4 brightness-0 invert" />
      <p class="text-white/70 text-sm leading-relaxed max-w-xs">
        Florida Disability Access and Awareness Foundation — a 501(c)(3) nonprofit using media to promote empathy and empowerment for the disability community.
      </p>
    </div>

    <!-- Navigation -->
    <div>
      <h3 class="font-display font-bold text-sm tracking-widest uppercase text-white/50 mb-4">Navigate</h3>
      <ul class="space-y-2">
        {[
          { label: 'Home', href: '/' },
          { label: 'Projects', href: '/projects/' },
          { label: 'About Us', href: '/about/' },
          { label: 'Volunteer', href: '/volunteer/' },
          { label: 'Donate', href: '/donate/' },
          { label: 'Contact', href: '/contact/' },
        ].map(link => (
          <li>
            <a href={link.href} class="text-white/70 hover:text-[#27CCC0] text-sm transition-colors">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Social & Contact -->
    <div>
      <h3 class="font-display font-bold text-sm tracking-widest uppercase text-white/50 mb-4">Connect</h3>
      <div class="flex gap-4 mb-4">
        <a href="https://twitter.com/FDAAFoundation" target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="text-white/70 hover:text-[#27CCC0] transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/fdaaf" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-white/70 hover:text-[#27CCC0] transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@fdaaf" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-white/70 hover:text-[#27CCC0] transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
      <p class="text-white/70 text-sm">
        <a href="mailto:info@fdaaf.org" class="hover:text-[#27CCC0] transition-colors">info@fdaaf.org</a>
      </p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-white/40 text-xs">
      <p>&copy; {year} Florida Disability Access and Awareness Foundation. All rights reserved.</p>
      <p>501(c)(3) Public Charity</p>
    </div>
  </div>
</footer>
