---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
}

const {
  title,
  description = "Florida Disability Access and Awareness Foundation — Creating media to promote understanding, empathy, and empowerment for the disability community.",
  ogImage = "/images/og-default.jpg",
  ogUrl,
} = Astro.props;

const siteOrigin = (Astro.site ?? Astro.url).origin;
const canonicalUrl = ogUrl ?? `${siteOrigin}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph / Google Ads -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | FDAAF`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteOrigin}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | FDAAF`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteOrigin}${ogImage}`} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700;1,900&family=Raleway:wght@300;400;500;600;700;900&family=Roboto:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title} | FDAAF</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-[#27CCC0] focus:text-white focus:px-4 focus:py-2 focus:rounded focus:text-sm focus:font-semibold">
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      // ── Scroll reveal with directional variants ──
      const reveals = document.querySelectorAll('.reveal');

      // Auto-assign animation direction based on element's horizontal position + index
      reveals.forEach((el, i) => {
        if (el.dataset.revealDir) return; // already set manually
        const rect = el.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const vw = window.innerWidth;
        // Alternate: pop for first-of-section, left/right based on viewport position, scale for small cards
        const isSmall = rect.width < vw * 0.4;
        if (isSmall) {
          el.dataset.revealDir = ['pop','up','pop','up'][i % 4];
        } else if (cx < vw * 0.4) {
          el.dataset.revealDir = 'left';
        } else if (cx > vw * 0.6) {
          el.dataset.revealDir = 'right';
        } else {
          el.dataset.revealDir = i % 3 === 0 ? 'pop' : 'up';
        }
      });

      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            obs.unobserve(e.target);
          }
        }),
        { threshold: 0.07, rootMargin: '0px 0px -40px 0px' }
      );
      reveals.forEach(el => obs.observe(el));

      // ── Magnetic hover on buttons ──
      document.querySelectorAll('.btn-teal, .btn-orange, .btn-ghost').forEach(btn => {
        btn.addEventListener('mousemove', (e) => {
          const r = btn.getBoundingClientRect();
          const x = ((e.clientX - r.left) / r.width - 0.5) * 10;
          const y = ((e.clientY - r.top) / r.height - 0.5) * 6;
          btn.style.transform = `translateY(-3px) rotateX(${-y}deg) rotateY(${x}deg) scale(1.04)`;
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.transform = '';
        });
      });
    </script>

    <!-- Ko-fi floating widget -->
    <script src="https://storage.ko-fi.com/cdn/scripts/overlay-widget.umd.min.js"></script>
    <script>
      kofiWidgetOverlay.draw('accessentreegame', {
        'type': 'floating-chat',
        'floating-chat.donateButton.text': 'Support Us',
        'floating-chat.donateButton.background-color': '#27CCC0',
        'floating-chat.donateButton.text-color': '#fff'
      });
    </script>
  </body>
</html>
